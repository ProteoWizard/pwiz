<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Pwiz.Vendor.Thermo</RootNamespace>
    <AssemblyName>Pwiz.Vendor.Thermo</AssemblyName>
    <Description>Thermo .raw reader. Uses ThermoFisher.CommonCore Net8 assemblies (cross-platform).</Description>

    <!--
      The Thermo SDK needs en-US culture internally (constructs CultureInfo("en-US") directly).
      Our root Directory.Build.props turns on InvariantGlobalization for core libraries; opt out
      here and in the test project so the Thermo SDK can load cultures without throwing.
      -->
    <InvariantGlobalization>false</InvariantGlobalization>

    <!--
      The Thermo assemblies are encrypted in pwiz_aux/msrc/utility/vendor_api_Thermo.7z.
      The ExtractThermoAssemblies target below unpacks them into $(ThermoAssembliesDir) on
      every build (idempotent — skipped if the files are already current).
      -->
    <ThermoArchive>$(MSBuildThisFileDirectory)..\..\..\..\pwiz_aux\msrc\utility\vendor_api_Thermo.7z</ThermoArchive>
    <ThermoAssembliesDir>$(MSBuildThisFileDirectory)..\..\..\vendor-assemblies\Thermo</ThermoAssembliesDir>
    <SevenZaExe>$(MSBuildThisFileDirectory)..\..\..\..\libraries\7za.exe</SevenZaExe>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Util\Util.csproj" />
    <ProjectReference Include="..\..\Common\Common.csproj" />
    <ProjectReference Include="..\..\MsData\MsData.csproj" />
    <ProjectReference Include="..\..\Analysis\Analysis.csproj" />
  </ItemGroup>

  <Target Name="ExtractThermoAssemblies"
          BeforeTargets="ResolveAssemblyReferences;ResolveReferences"
          Inputs="$(ThermoArchive)"
          Outputs="$(ThermoAssembliesDir)\ThermoFisher.CommonCore.RawFileReader.dll">
    <!--
      Extract vendor_api/Thermo/*.dll from the encrypted 7z on build. The
      -pi-agree-to-the-vendor-licenses password gates the archive (see make_Thermo_7z.bat).
      MSBuild's Inputs/Outputs drive incrementality: re-runs only when the 7z is newer than the
      flattened RawFileReader DLL.
      -->
    <MakeDir Directories="$(ThermoAssembliesDir)" />
    <Exec Command="&quot;$(SevenZaExe)&quot; x -y -pi-agree-to-the-vendor-licenses -o&quot;$(ThermoAssembliesDir)&quot; &quot;$(ThermoArchive)&quot; vendor_api\Thermo\*.dll" />
    <!-- Flatten the extracted layout so <HintPath> entries stay simple. -->
    <ItemGroup>
      <_ThermoDll Include="$(ThermoAssembliesDir)\vendor_api\Thermo\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_ThermoDll)"
          DestinationFolder="$(ThermoAssembliesDir)"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <Reference Include="ThermoFisher.CommonCore.Data">
      <HintPath>$(ThermoAssembliesDir)\ThermoFisher.CommonCore.Data.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="ThermoFisher.CommonCore.RawFileReader">
      <HintPath>$(ThermoAssembliesDir)\ThermoFisher.CommonCore.RawFileReader.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="ThermoFisher.CommonCore.BackgroundSubtraction">
      <HintPath>$(ThermoAssembliesDir)\ThermoFisher.CommonCore.BackgroundSubtraction.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="ThermoFisher.CommonCore.MassPrecisionEstimator">
      <HintPath>$(ThermoAssembliesDir)\ThermoFisher.CommonCore.MassPrecisionEstimator.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="OpenMcdf">
      <HintPath>$(ThermoAssembliesDir)\OpenMcdf.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="OpenMcdf.Extensions">
      <HintPath>$(ThermoAssembliesDir)\OpenMcdf.Extensions.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
