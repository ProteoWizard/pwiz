<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Native C++ DLL exposing a flat C surface around MBISDK. Built into
       MobilionShim.dll and consumed by Mobilion.csproj's P/Invoke surface.
       x64-only because MBI_SDK ships only an x64 import library. -->

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{4F2D8E61-72E3-4D54-8FB9-FCB4F1D6DAFB}</ProjectGuid>
    <RootNamespace>MobilionShim</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <Keyword>Win32Proj</Keyword>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <!-- UseDebugLibraries=false even in Debug: MBI_SDK.dll ships built against the
         release C runtime (/MD). Mixing /MDd here would give std::vector a different
         in-memory layout than the SDK and any vector returned by value across the DLL
         boundary access-violates on iteration. We still keep optimizations off and
         debug symbols on so the shim itself remains debuggable. -->
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>false</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- MBISDK headers + import library land here when Mobilion.csproj's
       ExtractMobilionAssemblies target unpacks vendor_api_Mobilion.7z. The
       .csproj sequences extraction before this build (MSBuild Exec). -->
  <PropertyGroup>
    <MobilionSdkDir>$(MSBuildThisFileDirectory)..\..\..\..\vendor-assemblies\Mobilion</MobilionSdkDir>
    <OutDir>$(MSBuildThisFileDirectory)bin\$(Configuration)\</OutDir>
    <IntDir>$(MSBuildThisFileDirectory)obj\$(Configuration)\</IntDir>
    <TargetName>MobilionShim</TargetName>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>MOBILION_SHIM_EXPORTS;_WINDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(MobilionSdkDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level3</WarningLevel>
      <ExceptionHandling>Sync</ExceptionHandling>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <!-- MultiThreadedDLL = /MD (release CRT). Required to match MBI_SDK.dll's CRT
           even in our Debug build, since std::vector and other STL types must share
           the same allocator/iterator layout across the DLL boundary or vector
           returns by value access-violate. -->
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <AdditionalLibraryDirectories>$(MobilionSdkDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>MBI_SDK.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="MobilionShim.cpp" />
    <ClInclude Include="MobilionShim.h" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
