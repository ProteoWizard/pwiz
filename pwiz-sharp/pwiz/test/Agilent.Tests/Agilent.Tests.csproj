<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.1" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Vendor\Agilent\Agilent.csproj" />
    <ProjectReference Include="..\..\src\TestHarness\TestHarness.csproj" />
  </ItemGroup>

  <!-- Agilent test fixtures ship as Reader_Agilent_Test.data.tar.bz2; unpack on build so
       the harness can find the .d directories. Without this, every test goes Inconclusive
       ("Agilent test data tree not found") on a fresh agent (TC, clean CI checkout, etc.). -->
  <PropertyGroup>
    <VendorTestArchive>$(MSBuildThisFileDirectory)..\..\..\..\pwiz\data\vendor_readers\Agilent\Reader_Agilent_Test.data.tar.bz2</VendorTestArchive>
    <VendorTestDataParent>$(MSBuildThisFileDirectory)..\..\..\..\pwiz\data\vendor_readers\Agilent</VendorTestDataParent>
  </PropertyGroup>
  <Import Project="..\..\..\build\ExtractTestData.targets" />

</Project>
