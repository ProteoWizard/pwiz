<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- UIMFLibrary's static constructor reads en-US-specific culture data; invariant
         mode (the .NET 8 default for trim-friendly apps) makes it throw
         CultureNotFoundException on first DataReader instantiation. -->
    <InvariantGlobalization>false</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.1" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Vendor\UIMF\UIMF.csproj" />
    <ProjectReference Include="..\..\src\TestHarness\TestHarness.csproj" />
  </ItemGroup>

  <!-- UIMF test fixtures ship as Reader_UIMF_Test.data.tar.bz2; unpack on build so the
       harness can find the .UIMF file. Without this, every test goes Inconclusive
       ("UIMF test data tree not found") on a fresh agent. -->
  <PropertyGroup>
    <VendorTestArchive>$(PwizCppRoot)\data\vendor_readers\UIMF\Reader_UIMF_Test.data.tar.bz2</VendorTestArchive>
    <VendorTestDataParent>$(PwizCppRoot)\data\vendor_readers\UIMF</VendorTestDataParent>
  </PropertyGroup>
  <Import Project="..\..\..\build\ExtractTestData.targets" />

</Project>
