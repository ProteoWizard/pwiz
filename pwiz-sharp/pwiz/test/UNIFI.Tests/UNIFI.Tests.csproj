<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.1" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Vendor\UNIFI\UNIFI.csproj" />
    <ProjectReference Include="..\..\src\TestHarness\TestHarness.csproj" />
    <ProjectReference Include="..\..\src\Analysis\Analysis.csproj" />
  </ItemGroup>

  <!-- Google.Protobuf is referenced through UNIFI.csproj as a HintPath Reference, which
       MSBuild treats as non-transitive for compile-time use in dependents. Re-declare it
       here so the test compilation can use Pwiz.Vendor.UNIFI.Protobuf types directly. -->
  <ItemGroup>
    <Reference Include="Google.Protobuf">
      <HintPath>$(PwizCppToolsRoot)\Shared\Lib\Google.Protobuf.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

</Project>
