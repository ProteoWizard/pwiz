bin/
obj/
.vs/
*.user
*.suo
TestResults/

# CMake build trees under examples/.
examples/**/build/

# Per-user MSBuild overrides written by i-agree-to-the-vendor-licenses.bat.
Directory.Build.user.props

# Vendor DLLs extracted from 7z archives at build time (see Bruker.csproj / Thermo.csproj).
vendor-assemblies/
installer/build/
installer/cache/
installer/staging/

# VendorSdkPins.generated.cs is regenerated on every build from the vendor 7z
# archives' SHA-256 + commit history (see Refresh-VendorPins.ps1, invoked as a
# pre-CoreCompile target in Vendor.Common.csproj). Keeping it tracked produced
# spurious dirty-tree failures on TC because cross-machine differences in line
# endings / archive timestamps would cause the regeneration to write a
# byte-different file even when the logical content matched.
src/Vendor/Common/VendorSdkPins.generated.cs
