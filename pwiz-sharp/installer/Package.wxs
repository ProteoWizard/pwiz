<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 5+ MSI for pwiz-sharp. Packages the MSConvertGUI Release build output (which
  also contains msconvert-sharp.exe via the project reference chain). Per-user
  install to %LOCALAPPDATA%\Programs\ProteoWizard-Sharp\ — no UAC prompt, no admin.

  Switch to per-machine by setting BuildScope=perMachine when running:
      wix build Package.wxs -d BuildScope=perMachine -o pwiz-sharp.msi

  Vendor SDK DLLs ARE currently bundled (Phase 1 — MSI is ~110 MB). Phase 2 will
  strip them and rely on Pwiz.Vendor.Common.VendorSdkLoader for on-demand fetch,
  shrinking the MSI to ~25 MB.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?define ProductName = "ProteoWizard-Sharp" ?>
  <?define Manufacturer = "ProteoWizard" ?>
  <?define UpgradeCode = "{6D8C7F6E-3B5A-4E2C-9A8D-1F2E3C4B5A60}" ?>

  <!-- Version comes from the AssemblyVersion of MSConvertGUI-sharp.exe at build time.
       For now hardcoded; wire to dotnet-determined version when CI integration lands. -->
  <?define Version = "0.1.0" ?>

  <!-- BuildScope: "perUser" (default) or "perMachine". Drives Package/@Scope, ALLUSERS,
       and the install-folder choice. -->
  <?define BuildScope = "perUser" ?>

  <!-- StagingDir: the filtered payload directory (built by installer/build.ps1, which
       strips vendor SDK DLLs + debug symbols + cross-platform runtimes from
       src/MsConvertGUI/bin/Release/net8.0-windows). Vendor SDKs come in on first use
       via Pwiz.Vendor.Common.VendorSdkLoader. -->
  <?define StagingDir = "build\stage" ?>

  <Package
      Name="$(ProductName)"
      Manufacturer="$(Manufacturer)"
      Version="$(Version)"
      UpgradeCode="$(UpgradeCode)"
      Scope="$(BuildScope)"
      InstallerVersion="500"
      Compressed="yes">

    <SummaryInformation
        Description="ProteoWizard-Sharp — msconvert-sharp + MSConvertGUI-sharp"
        Keywords="proteowizard,mass spectrometry,mzML,msconvert,pwiz" />

    <!-- MediaTemplate auto-creates the cabinet that holds the files. -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Install folder: %LOCALAPPDATA%\Programs\ProteoWizard-Sharp\ for perUser,
         %PROGRAMFILES%\ProteoWizard-Sharp\ for perMachine. -->
    <?if $(BuildScope) = "perUser" ?>
      <StandardDirectory Id="LocalAppDataFolder">
        <Directory Id="ProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="$(ProductName)" />
        </Directory>
      </StandardDirectory>
    <?else ?>
      <StandardDirectory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="$(ProductName)" />
      </StandardDirectory>
    <?endif ?>

    <!-- Start menu shortcut for MSConvertGUI-sharp. msconvert-sharp.exe is CLI; no
         shortcut needed (users add to PATH manually or invoke via full path). -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="$(ProductName)">
        <Component Id="StartMenuShortcuts" Guid="{8C7D6E5F-4A3B-2C1D-0E9F-8A7B6C5D4E3F}">
          <Shortcut Id="MSConvertGUIShortcut"
                    Name="MSConvertGUI-sharp"
                    Description="Convert vendor mass-spec data to mzML / mzXML / MGF"
                    Target="[INSTALLFOLDER]MSConvertGUI-sharp.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\$(Manufacturer)\$(ProductName)"
                         Name="StartMenuShortcuts"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Feature aggregating everything. WiX 5+ Files element pulls in every file
         under StagingDir; HeatDirectory was the WiX 3 way, we don't need it anymore. -->
    <Feature Id="Main" Title="$(ProductName)" Level="1" AllowAbsent="no">
      <Files Include="$(StagingDir)\**" />
      <ComponentRef Id="StartMenuShortcuts" />
    </Feature>

  </Package>
</Wix>
