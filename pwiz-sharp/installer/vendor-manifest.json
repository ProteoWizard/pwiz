{
  "schema": 1,

  // One entry per vendor_api_<Vendor>.7z archive. URLs point at the pwiz GitHub release
  // for the matching pwiz version. Bump `version` + republish a release asset whenever
  // a vendor SDK is updated; existing pwiz-sharp installs continue to pull the older
  // version they pinned (cache directory key is name-version).
  //
  // `sha256` is optional but recommended — VendorSdkLoader rejects + re-downloads on
  // mismatch. Compute via: `sha256sum vendor_api_<Vendor>.7z` (Linux) or `Get-FileHash
  // <path> -Algorithm SHA256` (PowerShell).
  //
  // `assemblyPrefixes` enumerates the simple-name prefixes that route to this vendor.
  // The AssemblyLoadContext.Resolving handler picks the first vendor whose prefix list
  // matches the requested assembly. Keep these sets disjoint.

