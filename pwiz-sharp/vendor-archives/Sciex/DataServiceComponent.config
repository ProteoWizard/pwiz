      <register name="SampleRepository" type="Clearcore2.Data.Core.Acquisition.ISampleRepository, Clearcore2.Data.Core" mapTo="Clearcore2.DataService.Repository.SampleRepository, Clearcore2.SampleData.ServerCommon">
        <lifetime type="singleton" />
