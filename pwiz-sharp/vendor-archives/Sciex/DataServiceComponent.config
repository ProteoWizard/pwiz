      <register name="AcquisitionDataWriter" type="Clearcore2.Data.Acquisition.Contracts.IAcquisitionSampleDataWriterClient, Clearcore2.Data.Acquisition.Contracts" mapTo="Clearcore2.Data.Acquisition.Client.AcquisitionSampleDataWriterClient, Clearcore2.Data.Acquisition.Client">
        <constructor/>
        <lifetime type="singleton"/>
