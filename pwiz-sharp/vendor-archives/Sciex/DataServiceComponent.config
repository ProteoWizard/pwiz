      <register name="ProcessingMethodsProvider" type="Clearcore2.Data.Acquisition.Contracts.IProcessingMethodsProviderClient, Clearcore2.Data.Acquisition.Contracts" mapTo="Clearcore2.Data.Acquisition.Client.ProcessingMethodsProviderClient, Clearcore2.Data.Acquisition.Client">
