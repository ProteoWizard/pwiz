        <lifetime type="singleton"/>
      </register>

      <!-- IRecalFileAccess -->
      <register name="RecalFileAccess" type="ClearCore2.SampleData.Recalibration.IRecalFileAccess, ClearCore2.SampleData.Recalibration"
                  mapTo="ClearCore2.SampleData.Recalibration.RecalFileAccess, ClearCore2.SampleData.Recalibration" >
        <lifetime type="singleton"/>
      </register>


      <!-- IRecalSingleSelection -->
      <!-- Note: constructor params must have dependency defined or param resolution will fail "x is an interface are you missing a reference?" -->
      <register name="RecalSingleSelection" type="ClearCore2.SampleData.Recalibration.IRecalSingleSelection, ClearCore2.SampleData.Recalibration"
                  mapTo="ClearCore2.SampleData.Recalibration.RecalSingleSelection, ClearCore2.SampleData.Recalibration" >
        <constructor>
          <param name="notifier">
            <dependency name="RecalNotification" />
          </param>
          <param name="fileAccess">
            <dependency name="RecalFileAccess" />
          </param>
        </constructor>
        <lifetime type="singleton"/>
      </register>

      <!-- IRecalSettingsProvider -->
      <register name="RecalSettingsProvider" type="ClearCore2.SampleData.Recalibration.IRecalSettingsProvider, ClearCore2.SampleData.Recalibration"
                  mapTo="ClearCore2.SampleData.Recalibration.RecalSettingsProvider, ClearCore2.SampleData.Recalibration" >
        <lifetime type="singleton"/>
      </register>

      <!-- IRecalibrator -->
      <!-- Note: constructor params must have dependency defined or param resolution will fail "x is an interface are you missing a reference?" -->
      <register name="RecalibrationProvider" type="Clearcore2.SampleData.Client.Contracts.Recalibration.IRecalibrationProvider, Clearcore2.SampleData.Client.Contracts"
                mapTo="ClearCore2.SampleData.Recalibration.RecalEngine, ClearCore2.SampleData.Recalibration" >
        <constructor>
          <param name="singleRecalProcessor">
            <dependency name="RecalSingleSelection" />
          </param>
          <param name="settingsProvider">
            <dependency name="RecalSettingsProvider" />
          </param>
        </constructor>
        <lifetime type="singleton"/>
      </register>
      <!-- Recalibration section end -->

