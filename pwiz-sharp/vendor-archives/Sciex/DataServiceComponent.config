      <register name="UserSettingsDataProvider" type="Clearcore2.Data.Acquisition.Contracts.IUserSettingsDataProviderClient, Clearcore2.Data.Acquisition.Contracts" mapTo="Clearcore2.Data.Acquisition.Client.UserSettingsDataProviderClient, Clearcore2.Data.Acquisition.Client">
        <constructor/>
        <lifetime type="singleton"/>
      </register>

      <register name="ServiceLogDataProvider" type="Clearcore2.Data.Acquisition.Contracts.IServiceLogDataProviderClient, Clearcore2.Data.Acquisition.Contracts" mapTo="Clearcore2.Data.Acquisition.Client.ServiceLogDataProviderClient, Clearcore2.Data.Acquisition.Client">
        <constructor/>
        <lifetime type="singleton"/>
