        <constructor>
          <param name="storageLocationPool">
            <dependency name="StorageLocationPool" />
          </param>
          <param name="acquiringSampleTracker">
            <dependency name="AcquiringSampleTracker" />
          </param>
        </constructor>
        <lifetime type="singleton"/>
      </register>

