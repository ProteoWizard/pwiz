    n_utility__chemistry__Chemistry [label="Chemistry", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Element / Formula / Mass arithmetic. Ported as Util/Chemistry/Formula.cs + Element*.cs +&#10;PhysicalConstants.cs. Generated 118-element table from cpp via Chemistry/generate_elements.py.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/Chemistry.cpp", target="_blank"];
    n_utility__chemistry__ChemistryData [label="ChemistryData", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Generated isotope masses + abundances for all 118 elements. Ported as Util/Chemistry/ChemistryData.generated.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/ChemistryData.cpp", target="_blank"];
    n_utility__chemistry__Ion [label="Ion", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="m/z-from-mass-and-charge helpers. Ported as Util/Chemistry/Ion.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/Ion.hpp", target="_blank"];
    n_utility__chemistry__IsotopeCalculator [label="IsotopeCalculator", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Isotope-envelope distribution calculator. Ported as Util/Chemistry/IsotopeCalculator.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/IsotopeCalculator.cpp", target="_blank"];
    n_utility__chemistry__IsotopeEnvelopeEstimator [label="IsotopeEnvelopeEstimator", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Statistical fit of isotope-envelope shapes. NOT PORTED — no current consumer.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/IsotopeEnvelopeEstimator.cpp", target="_blank"];
    n_utility__chemistry__IsotopeTable [label="IsotopeTable", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Per-element isotope table. Ported as Util/Chemistry/IsotopeTable.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/IsotopeTable.cpp", target="_blank"];
    n_utility__chemistry__MZTolerance [label="MZTolerance", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="m/z tolerance ppm/Da arithmetic. Ported as Util/Chemistry/MZTolerance.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/utility/chemistry/MZTolerance.cpp", target="_blank"];
