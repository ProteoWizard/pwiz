digraph pwiz_module_detail {
  rankdir=TB;
  labelloc=t;
  label=<<b>pwiz/data/common — file-level port status</b><br/><font point-size="10">one node per .cpp/.hpp pair (test fixtures omitted); each group is its own row, top-to-bottom</font>>;
  fontname="Segoe UI";
  node [shape=box, style="filled,rounded", fontname="Segoe UI", fontsize=10];
  edge [color="#444"];
  ranksep=0.6; nodesep=0.2;
  compound=true;
  newrank=true;
  splines=false;
  subgraph cluster_data_common_CV_OBO {
    label=<<b>CV / OBO</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__common__CVTranslator [label="CVTranslator", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Free-text → CVID heuristic mapper (vendor name strings → MS_LCMS_xxx).&#10;Ported as Common/Cv/CvTranslator.cs. Used by every vendor Reader's&#10;TranslateInstrumentModel helper.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/CVTranslator.cpp", target="_blank"];
    n_data__common__Unimod [label="Unimod", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Unimod modification database.&#10;Ported as Common/Cv/Unimod.cs with embedded unimod.obo + populated specificity&#10;tables (real Δmono/Δavg masses, per-AA-position specificities).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/Unimod.cpp", target="_blank"];
    n_data__common__cv [label="cv", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Auto-generated PSI-MS controlled-vocabulary table.&#10;Ported as Common/Cv/CVID.generated.cs (~30K enum entries) plus CvLookup&#10;for term name/ID lookup. Generated by Common/Cv/generate_cvid.py from cv.hpp.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/cv.cpp", target="_blank"];
    n_data__common__cvgen [label=<<s>cvgen</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Code-gen tool — replaced by Common/Cv/generate_cvid.py (Python).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/cvgen.cpp", target="_blank"];
    n_data__common__cvgen_common [label=<<s>cvgen_common</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Code-gen helpers — folded into generate_cvid.py.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/cvgen_common.hpp", target="_blank"];
    n_data__common__obo [label="obo", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="OBO 1.2 parser. Ported as Common/Cv/OboParser.cs.&#10;Drives the cv / unit / unimod term tables from embedded .obo resources at&#10;Common/Cv/Resources/. Round-trip parity tests live in Common.Tests.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/obo.cpp", target="_blank"];
    n_data__common__CVTranslator -> n_data__common__Unimod -> n_data__common__cv -> n_data__common__cvgen -> n_data__common__cvgen_common -> n_data__common__obo [style=invis, constraint=false];
  }
  subgraph cluster_data_common_Param_Diff {
    label=<<b>Param / Diff</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__common__ParamTypes [label="ParamTypes", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="ParamContainer / ParamGroup / CVParam / UserParam.&#10;Ported as Common/Params/ParamContainer.cs + CvParam.cs + UserParam.cs.&#10;Same accessor surface as cpp (Set/Get/HasCVParam/cvParamChild/UserParams).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/ParamTypes.cpp", target="_blank"];
    n_data__common__diff_std [label="diff_std", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Generic diff infrastructure: Diff<T>, DiffConfig, DiffResult<T>.&#10;Ported as Common/Diff.cs. Drives MSData/IdentData round-trip parity&#10;tests + the msdiff tool replacement.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/diff_std.cpp", target="_blank"];
    n_data__common__ParamTypes -> n_data__common__diff_std [style=invis, constraint=false];
  }
  subgraph cluster_data_common_Index {
    label=<<b>Index</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__common__BinaryIndexStream [label="BinaryIndexStream", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Random-access index serialized to a binary stream (used by mzML offset cache).&#10;Ported as Common/Index/BinaryIndexStream.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/BinaryIndexStream.cpp", target="_blank"];
    n_data__common__Index [label="Index", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="IIndex interface satisfied by both MemoryIndex + BinaryIndexStream.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/Index.hpp", target="_blank"];
    n_data__common__MemoryIndex [label="MemoryIndex", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="In-memory IIndex implementation. Ported as Common/Index/MemoryIndex.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/common/MemoryIndex.cpp", target="_blank"];
    n_data__common__BinaryIndexStream -> n_data__common__Index -> n_data__common__MemoryIndex [style=invis, constraint=false];
  }
  n_data__common__CVTranslator -> n_data__common__ParamTypes [style=invis, minlen=1];
  n_data__common__ParamTypes -> n_data__common__BinaryIndexStream [style=invis, minlen=1];
  subgraph cluster_legend {
    label=<<b>Status</b>>;
    style="rounded";
    color="#444";
    fontname="Segoe UI";
    fontsize=11;
    margin=8;
    rank=same;
    legend_full [label="ported", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10"];
    legend_partial [label="partial", fillcolor="#ffe48a", color="#a87000", fontcolor="#4a3000"];
    legend_none [label="not yet ported", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a"];
    legend_skipped [label=<<s>won't port (BCL/legacy)</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555"];
    legend_full -> legend_partial -> legend_none -> legend_skipped [style=invis, constraint=false];
  }
  n_data__common__BinaryIndexStream -> legend_full [style=invis, minlen=1];
}
