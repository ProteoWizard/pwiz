    label=<<b>Reader dispatch</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__DefaultReaderList [label="DefaultReaderList", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Reader dispatcher (mzML / mzXML / MGF + vendor extension points).&#10;Ported as MsData/Readers/ReaderList.cs. Vendor readers register at startup&#10;(see MsConvert/Converter ctor).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/DefaultReaderList.cpp", target="_blank"];
    n_data__msdata__Reader [label="Reader", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="IReader interface + ReaderConfig. Ported as MsData/IReader.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Reader.cpp", target="_blank"];
    n_data__msdata__DefaultReaderList -> n_data__msdata__Reader [style=invis, constraint=false];
