    n_data__msdata__ramp__ramp [label=<<s>ramp</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Legacy mzXML-style reader (ramp.h / ramp.cpp). Intentionally NOT PORTED — superseded by Pwiz.Data.MsData.Mzml.MzmlReader; deprecated in upstream cpp too.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/ramp/ramp.cpp", target="_blank"];
