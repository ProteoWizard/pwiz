  subgraph cluster_data_msdata_Misc {
    label=<<b>Misc</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__MemoryMRUCache [label="MemoryMRUCache", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Bounded LRU cache (least-recently-used eviction).&#10;Ported as Util/Collections/LruCache.cs. Used by SpectrumList_ChargeFromIsotope&#10;for parent MS1 spectra.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/MemoryMRUCache.hpp", target="_blank"];
    n_data__msdata__RAMPAdapter [label=<<s>RAMPAdapter</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Legacy C-API shim wrapping pwiz to look like ISB RAMP — used by older readers.&#10;Not used by msconvert / Skyline. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/RAMPAdapter.cpp", target="_blank"];
    n_data__msdata__SpectrumWorkerThreads [label="SpectrumWorkerThreads", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Multi-threaded spectrum reader (used by mzML writer to overlap read+encode).&#10;Not ported: pwiz-sharp is single-threaded for now; the speed gap is small for&#10;modern hardware vs. the porting risk.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumWorkerThreads.cpp", target="_blank"];
    n_data__msdata__examples [label="examples", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Canonical example MSData fixture builder. Ported as MsData/Examples.cs.&#10;InitializeTiny → 5 spectra (MS1/MS2 CID/no-data/MS2 ETD+CID/MALDI) + 2 chromatograms&#10;(TIC + SIC). AddMiapeExampleMetadata layers MIAPE-compliant metadata on top.&#10;Used by round-trip / Diff / serializer parity tests.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/examples.cpp", target="_blank"];
    n_data__msdata__MemoryMRUCache -> n_data__msdata__RAMPAdapter -> n_data__msdata__SpectrumWorkerThreads -> n_data__msdata__examples [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_HDF5_mz5_ {
    label=<<b>HDF5 (mz5)</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__mz5__Configuration_mz5 [label="Configuration_mz5", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mz5/HDF5 file-level config. Ported as MsData/Mz5/Mz5Configuration.cs + Mz5Datasets.cs (dataset-name enum + version/length constants matching cpp).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/Configuration_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__Connection_mz5 [label="Connection_mz5", fillcolor="#ffe48a", color="#a87000", fontcolor="#4a3000", tooltip="mz5 H5File wrapper. Read paths ported as MsData/Mz5/Mz5Connection.cs — file open + ReadFull/ReadDoubles + vlen-reclaim + refcounted shared ownership for SpectrumList + ChromatogramList. Write paths not done.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/Connection_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__Datastructures_mz5 [label="Datastructures_mz5", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mz5 typed structs. Ported as MsData/Mz5/Mz5Types.cs — all 25 POD record types with HDF5 compound type registrations whose field names match cpp's exactly (HDF5 matches compound fields by name on read — mismatches silently leave struct fields at zero).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/Datastructures_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__ReferenceRead_mz5 [label="ReferenceRead_mz5", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mz5 ID-resolution on read. Ported as MsData/Mz5/Mz5ReferenceRead.cs — walks document-level metadata in cpp's dependency order (CVs → CVReference → CVParam/UserParam/RefParam tables → ParamGroups → SourceFiles / Software / DataProcessings / Samples / ScanSettings / InstrumentConfigurations → Run → Spectrum/Chromatogram lists). Memoizes CVID lookups.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/ReferenceRead_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__ReferenceWrite_mz5 [label=<<s>ReferenceWrite_mz5</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="mz5 write-side ID resolution. Intentionally NOT PORTED — pwiz-sharp covers HDF5-backed output via mzMLb; mz5 stays read-only so we don't carry two parallel writers.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/ReferenceWrite_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__Translator_mz5 [label="Translator_mz5", fillcolor="#ffe48a", color="#a87000", fontcolor="#4a3000", tooltip="mz5 ↔ MSData translation. Reverse direction (delta-mz cumulative-sum + log-intensity decode on read) is in Mz5Connection / Mz5SpectrumList; forward translation for write intentionally not ported.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mz5/Translator_mz5.cpp", target="_blank"];
    n_data__msdata__mz5__Configuration_mz5 -> n_data__msdata__mz5__Connection_mz5 -> n_data__msdata__mz5__Datastructures_mz5 -> n_data__msdata__mz5__ReferenceRead_mz5 -> n_data__msdata__mz5__ReferenceWrite_mz5 -> n_data__msdata__mz5__Translator_mz5 [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_HDF5_mzMLb_ {
    label=<<b>HDF5 (mzMLb)</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__mzmlb__Connection_mzMLb [label="Connection_mzMLb", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mzMLb (HDF5-backed mzML) connection wrapper. Ported as Pwiz.Data.MsData.MzMlb.MzMlbConnection (HDF.PInvoke-backed, exposes mzML XML as a seekable Stream + typed Append/Read for binary datasets). Reader/Writer adapters at MzMlbReaderAdapter / MzMlbWriter; integration into MzmlReader/MzmlWriter via IExternalBinarySource/Sink. Bidirectional cpp parity verified.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/mzmlb/Connection_mzMLb.cpp", target="_blank"];
  }
  subgraph cluster_data_msdata_Other {
    label=<<b>Other</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
