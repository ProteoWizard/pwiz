    n_data__msdata__SpectrumList_MGF [label="SpectrumList_MGF", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lazy-load MGF SpectrumList. Ported as MsData/Mgf/SpectrumList_Mgf.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumList_MGF.cpp", target="_blank"];
    n_data__msdata__SpectrumList_MSn [label="SpectrumList_MSn", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Legacy MS1/MS2 SpectrumList. NOT PORTED — paired with Serializer_MSn.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumList_MSn.cpp", target="_blank"];
    n_data__msdata__SpectrumList_mz5 [label="SpectrumList_mz5", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mz5 SpectrumList. Ported as MsData/Mz5/Mz5SpectrumList.cs — lazy slicer over the global SpectrumMZ + SpectrumIntensity datasets via SpectrumIndex end-offsets. Reverses delta-mz encoding via cumulative sum when FileInformation.deltaMZ is set.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumList_mz5.cpp", target="_blank"];
    n_data__msdata__SpectrumList_mzML [label="SpectrumList_mzML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lazy-load mzML SpectrumList implementation. Ported as MsData/Mzml/SpectrumList_Mzml.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumList_mzML.cpp", target="_blank"];
    n_data__msdata__SpectrumList_mzXML [label="SpectrumList_mzXML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lazy-load mzXML SpectrumList. Ported as MsData/MzXml/SpectrumList_Mzxml.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumList_mzXML.cpp", target="_blank"];
    n_data__msdata__SpectrumList_BTDX -> n_data__msdata__SpectrumList_MGF -> n_data__msdata__SpectrumList_MSn -> n_data__msdata__SpectrumList_mz5 -> n_data__msdata__SpectrumList_mzML -> n_data__msdata__SpectrumList_mzXML [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_ChromatogramList_ {
    label=<<b>ChromatogramList_*</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__ChromatogramList_mz5 [label="ChromatogramList_mz5", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mz5 ChromatogramList. Ported as MsData/Mz5/Mz5ChromatogramList.cs — lazy slicer over ChromatogramTime + ChromatogramIntensity via ChromatogramIndex. No translator (mz5's delta encoding only applies to m/z, not time).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/ChromatogramList_mz5.cpp", target="_blank"];
    n_data__msdata__ChromatogramList_mzML [label="ChromatogramList_mzML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lazy-load mzML ChromatogramList. Ported as MsData/Mzml/ChromatogramList_Mzml.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/ChromatogramList_mzML.cpp", target="_blank"];
    n_data__msdata__ChromatogramList_mz5 -> n_data__msdata__ChromatogramList_mzML [style=invis, constraint=false];
  }
