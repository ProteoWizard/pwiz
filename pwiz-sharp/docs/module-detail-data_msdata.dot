digraph pwiz_module_detail {
  rankdir=TB;
  labelloc=t;
  label=<<b>pwiz/data/msdata — file-level port status</b><br/><font point-size="10">one node per .cpp/.hpp pair (test fixtures omitted); each group is its own row, top-to-bottom</font>>;
  fontname="Segoe UI";
  node [shape=box, style="filled,rounded", fontname="Segoe UI", fontsize=10];
  edge [color="#444"];
  ranksep=0.6; nodesep=0.2;
  compound=true;
  newrank=true;
  splines=false;
  subgraph cluster_data_msdata_Core_model {
    label=<<b>Core model</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__ChromatogramListBase [label="ChromatogramListBase", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Same as SpectrumListBase but for ChromatogramList. Ported as MsData/Chromatograms/ChromatogramListBase.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/ChromatogramListBase.hpp", target="_blank"];
    n_data__msdata__Diff [label="Diff", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MSData-specific diff specialization (knows how to walk Run/Spectrum/CV nesting).&#10;Ported as MsData/Diff/MSDataDiff.cs. Drives msconvert-cpp parity tests.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Diff.cpp", target="_blank"];
    n_data__msdata__LegacyAdapter [label="LegacyAdapter", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Pre-2010 adapter that synthesized PSI-MS terms from old free-text fields.&#10;Not needed: modern vendor readers set CV terms directly. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/LegacyAdapter.cpp", target="_blank"];
    n_data__msdata__MSData [label="MSData", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Top-level MSData container model.&#10;Ported as MsData/MSData.cs + Run.cs + FileDescription.cs + Software.cs +&#10;Scan/Spectrum/Chromatogram property bags. All field names PascalCase, IDisposable&#10;for vendor handles.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/MSData.cpp", target="_blank"];
    n_data__msdata__MSDataFile [label="MSDataFile", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="✓ calculateSHA1Checksums   →  MSDataFile.CalculateSha1Checksums()&#10;✓ WriteConfig + Format     →  Pwiz.Data.MsData.WriteConfig + WriteFormat&#10;✓ Precision / Compression  →  Encoding.BinaryPrecision / BinaryCompression&#10;✓ write(msd,path,cfg)      →  MSDataFile.Write — dispatches to MzmlWriter /&#10;                              MzxmlWriter / MgfSerializer based on WriteConfig.Format&#10;✗ detect(filename)         →  not yet ported; Reader.Identify() does sniff-by-extension", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/MSDataFile.cpp", target="_blank"];
    n_data__msdata__MSDataMerger [label="MSDataMerger", fillcolor="#ffe48a", color="#a87000", fontcolor="#4a3000", tooltip="PARTIAL — multi-file merge into a single MSData.&#10;Done inline inside MsConvert/Converter.MergeRun (concatenates SourceFiles +&#10;Software + spectra). No standalone class yet.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/MSDataMerger.cpp", target="_blank"];
    n_data__msdata__References [label="References", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Resolves IDREF cross-references inside an MSData graph (e.g., scan.spectrumRef → spectrum).&#10;Ported as MsData/References.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/References.cpp", target="_blank"];
    n_data__msdata__SpectrumInfo [label="SpectrumInfo", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lightweight per-scan metadata struct. Ported as MsData/Spectra/SpectrumInfo.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumInfo.cpp", target="_blank"];
    n_data__msdata__SpectrumIterator [label="SpectrumIterator", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Scan-time spectrum iterator. Ported as MsData/Spectra/SpectrumIterator.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumIterator.cpp", target="_blank"];
    n_data__msdata__SpectrumListBase [label="SpectrumListBase", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Base class with shared SpectrumList plumbing. Ported as MsData/Spectra/SpectrumListBase.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumListBase.cpp", target="_blank"];
    n_data__msdata__SpectrumListCache [label="SpectrumListCache", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="LRU-caching SpectrumList decorator. Ported as MsData/Spectra/SpectrumListCache.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumListCache.cpp", target="_blank"];
    n_data__msdata__SpectrumListWrapper [label="SpectrumListWrapper", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Spectrum-list pass-through base class. Ported as Analysis/SpectrumListWrapper.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SpectrumListWrapper.hpp", target="_blank"];
    n_data__msdata__ChromatogramListBase -> n_data__msdata__Diff -> n_data__msdata__LegacyAdapter -> n_data__msdata__MSData -> n_data__msdata__MSDataFile -> n_data__msdata__MSDataMerger -> n_data__msdata__References -> n_data__msdata__SpectrumInfo -> n_data__msdata__SpectrumIterator -> n_data__msdata__SpectrumListBase -> n_data__msdata__SpectrumListCache -> n_data__msdata__SpectrumListWrapper [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_Encoding {
    label=<<b>Encoding</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__BinaryDataEncoder [label="BinaryDataEncoder", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="32-/64-bit float + zlib + numpress encoder for mzML binaryDataArrays.&#10;Ported as MsData/BinaryDataEncoder.cs with full numpress (Pic/Linear/Slof) +&#10;MS-NUMPRESS Apache port.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/BinaryDataEncoder.cpp", target="_blank"];
    n_data__msdata__MSNumpress [label="MSNumpress", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MS-NUMPRESS algorithm. Ported as MsData/Encoding/MsNumpress.cs (line-by-line port).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/MSNumpress.cpp", target="_blank"];
    n_data__msdata__SHA1OutputObserver [label="SHA1OutputObserver", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Streaming SHA-1 + byte counter wrapper around an std::ostream.&#10;Ported as MsData/Mzml/HashingCountingStream.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/SHA1OutputObserver.hpp", target="_blank"];
    n_data__msdata__BinaryDataEncoder -> n_data__msdata__MSNumpress -> n_data__msdata__SHA1OutputObserver [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_Serializers_writers {
    label=<<b>Serializers / writers</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__Serializer_MGF [label="Serializer_MGF", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MGF writer (Mascot Generic Format — MS2 peak-list export).&#10;Ported as MsData/Mgf/MgfSerializer.cs (text-mode writer with TPP-compat title formats).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Serializer_MGF.cpp", target="_blank"];
    n_data__msdata__Serializer_MSn [label="Serializer_MSn", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Legacy MS1/MS2/CMS1/CMS2 format. NOT PORTED — narrow user base.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Serializer_MSn.cpp", target="_blank"];
    n_data__msdata__Serializer_mz5 [label="Serializer_mz5", fillcolor="#ffe48a", color="#a87000", fontcolor="#4a3000", tooltip="HDF5-based mz5 serializer. READ ported as Mz5ReaderAdapter + Mz5Connection + Mz5ReferenceRead + Mz5SpectrumList + Mz5ChromatogramList (under MsData/Mz5/). Writer not done — round-trip tests shell out to cpp msconvert --mz5 for the write side.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Serializer_mz5.cpp", target="_blank"];
    n_data__msdata__Serializer_mzML [label="Serializer_mzML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Full mzML reader+writer. Ported as MsData/Mzml/MzmlReader.cs + MzmlWriter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Serializer_mzML.cpp", target="_blank"];
    n_data__msdata__Serializer_mzXML [label="Serializer_mzXML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Full mzXML reader+writer. Ported as MsData/MzXml/MzxmlReader.cs + MzxmlWriter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Serializer_mzXML.cpp", target="_blank"];
    n_data__msdata__TextWriter [label="TextWriter", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Format_Text output (a pwiz-internal pretty-print).&#10;Never wired in any GUI/CLI we care about. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/TextWriter.hpp", target="_blank"];
    n_data__msdata__Serializer_MGF -> n_data__msdata__Serializer_MSn -> n_data__msdata__Serializer_mz5 -> n_data__msdata__Serializer_mzML -> n_data__msdata__Serializer_mzXML -> n_data__msdata__TextWriter [style=invis, constraint=false];
  }
  subgraph cluster_data_msdata_mzML_stream_parser {
    label=<<b>mzML stream parser</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_data__msdata__IO [label="IO", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Streaming mzML element-by-element reader + writer.&#10;Ported as MsData/Mzml/MzmlReader.cs + MzmlWriter.cs (System.Xml.XmlReader/XmlWriter&#10;instead of cpp's SAXParser/XMLWriter).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/IO.cpp", target="_blank"];
    n_data__msdata__Index_mzML [label="Index_mzML", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="mzML spectrum/chromatogram offset index reader.&#10;Ported as MsData/Mzml/MzmlIndexReader.cs. Reads <indexList> trailer to seek to&#10;individual spectra without parsing the full file.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/msdata/Index_mzML.cpp", target="_blank"];
    n_data__msdata__IO -> n_data__msdata__Index_mzML [style=invis, constraint=false];
  }
