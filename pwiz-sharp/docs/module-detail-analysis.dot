digraph pwiz_module_detail {
  rankdir=TB;
  labelloc=t;
  label=<<b>pwiz/analysis — file-level port status</b><br/><font point-size="10">one node per .cpp/.hpp pair (test fixtures omitted); each group is its own row, top-to-bottom</font>>;
  fontname="Segoe UI";
  node [shape=box, style="filled,rounded", fontname="Segoe UI", fontsize=10];
  edge [color="#444"];
  ranksep=0.6; nodesep=0.2;
  compound=true;
  newrank=true;
  splines=false;
  subgraph cluster_analysis_spectrum_processing {
    label=<<b>spectrum_processing</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_analysis__spectrum_processing__MS2Deisotoper [label="MS2Deisotoper", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MS2 isotope-cluster deisotoper. Ported as Analysis/PeakFilters/Ms2Deisotoper.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/MS2Deisotoper.cpp", target="_blank"];
    n_analysis__spectrum_processing__MS2NoiseFilter [label="MS2NoiseFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MS2 noise-floor trimmer. Ported as Analysis/PeakFilters/Ms2NoiseFilter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/MS2NoiseFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__MzShiftFilter [label="MzShiftFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Apply a constant m/z shift. Ported as Analysis/SpectrumListMzShift.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/MzShiftFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__PrecursorMassFilter [label="PrecursorMassFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="ETD precursor / charge-reduced / neutral-loss removal. Ported as Analysis/PeakFilters/EtdPrecursorMassFilter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/PrecursorMassFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__PrecursorRecalculator [label="PrecursorRecalculator", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Helper for SpectrumList_PrecursorRecalculator. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/PrecursorRecalculator.hpp", target="_blank"];
    n_analysis__spectrum_processing__PrecursorRecalculatorDefault [label="PrecursorRecalculatorDefault", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Default precursor-recalc impl. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/PrecursorRecalculatorDefault.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumListFactory [label="SpectrumListFactory", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Filter-spec parser + dispatcher (\"peakPicking true 1-\", \"msLevel 1-2\", etc.).&#10;Ported as Analysis/SpectrumListFactory.cs with the full msconvert filter grammar.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumListFactory.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_3D [label=<<s>SpectrumList_3D</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="3D (m/z, drift-time, intensity) reshaper. WON'T PORT — niche, not on the pwiz-sharp roadmap.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_3D.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_ChargeFromIsotope [label="SpectrumList_ChargeFromIsotope", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Turbocharger — isotope-pattern precursor-charge predictor.&#10;Ported as Analysis/SpectrumList_ChargeFromIsotope.cs with cpp-bit-exact MsvcRand&#10;for pre-simulated distributions + LRU parent-spectrum cache.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_ChargeFromIsotope.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_ChargeStateCalculator [label="SpectrumList_ChargeStateCalculator", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Heuristic precursor-charge predictor (single-vs-multi, MS1-window based).&#10;Ported as Analysis/SpectrumList_ChargeStateCalculator.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_ChargeStateCalculator.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_Demux [label="SpectrumList_Demux", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="DIA/MSX demultiplexer wrapper. Ported as Analysis/SpectrumListDemux.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_Demux.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_DiaUmpire [label="SpectrumList_DiaUmpire", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="DIA-Umpire MS2 deconvolution wrapper. Ported as Analysis/DiaUmpire/SpectrumList_DiaUmpire.cs. The full DIA-Umpire algorithm (PeakCluster + PeakCurve + IsotopePatternMap + Config + DiaWindow + DiaUmpireMath + ScanData + InstrumentParameter) lives alongside it under Analysis/DiaUmpire/.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_DiaUmpire.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_Filter [label="SpectrumList_Filter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Generic index/scanTime/msLevel/polarity/scanNumber/id predicate filter. Ported as Analysis/SpectrumListFilter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_Filter.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_IonMobility [label="SpectrumList_IonMobility", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Ion-mobility CCS calculator filter. NOT YET PORTED — needs to be ported once an ion-mobility-capable vendor reader needs it; the vendor reader implementations themselves wire in the CCS conversion.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_IonMobility.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_LockmassRefiner [label="SpectrumList_LockmassRefiner", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Lock-mass m/z correction (Waters Q-TOF use case).&#10;Ported as Analysis/SpectrumList_LockmassRefiner.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_LockmassRefiner.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_MZRefiner [label="SpectrumList_MZRefiner", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="External-search-result-driven m/z recalibration (mzRefiner filter).&#10;Ported as Analysis/SpectrumList_MZRefiner.cs with full cpp parity (7+ stat passes,&#10;polynomial / shift-only / global / per-scan refinement modes).", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_MZRefiner.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_MZWindow [label="SpectrumList_MZWindow", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="m/z range window filter. Ported as Analysis/SpectrumListMzWindow.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_MZWindow.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_MetadataFixer [label="SpectrumList_MetadataFixer", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Re-derive BPI / TIC / scanWindow from peaks. Ported as Analysis/SpectrumListMetadataFixer.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_MetadataFixer.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_PeakFilter [label="SpectrumList_PeakFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Framework for per-spectrum peak filters (ETD precursor / charge-reduced / neutral-loss). Ported as Analysis/PeakFilters/.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_PeakFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_PeakPicker [label="SpectrumList_PeakPicker", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Vendor + CWT + local-maximum centroider. Ported as Analysis/SpectrumList_PeakPicker.cs + Analysis/PeakPicking/CwtPeakDetector.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_PeakPicker.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_PrecursorRecalculator [label="SpectrumList_PrecursorRecalculator", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Re-derive precursor m/z from MS1 (older approach than PrecursorRefine). NOT PORTED — superseded.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_PrecursorRecalculator.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_PrecursorRefine [label="SpectrumList_PrecursorRefine", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Re-derive precursor m/z from peak-fitted MS1. Ported as Analysis/SpectrumList_PrecursorRefine.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_PrecursorRefine.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_ScanSummer [label="SpectrumList_ScanSummer", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Sum adjacent scans by retention time. Ported as Analysis/SpectrumListScanSummer.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_ScanSummer.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_Smoother [label="SpectrumList_Smoother", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Savitzky-Golay smoother. Ported as Analysis/SpectrumList_Smoother.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_Smoother.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_Sorter [label="SpectrumList_Sorter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Re-sort spectra by scanTime / scanNumber / ID. Ported as Analysis/SpectrumListSorter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_Sorter.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_TitleMaker [label="SpectrumList_TitleMaker", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="TPP-compatible spectrum-title templater. Ported as Analysis/SpectrumListTitleMaker.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_TitleMaker.cpp", target="_blank"];
    n_analysis__spectrum_processing__SpectrumList_ZeroSamplesFilter [label="SpectrumList_ZeroSamplesFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Insert / remove zero-intensity samples around profile peaks. Ported as Analysis/SpectrumListZeroSamplesFilter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/SpectrumList_ZeroSamplesFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__ThresholdFilter [label="ThresholdFilter", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Per-spectrum intensity thresholder (count / count-after-ties / absolute / bpi-relative /&#10;tic-relative / tic-cutoff). Ported as Analysis/ThresholdFilter.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/spectrum_processing/ThresholdFilter.cpp", target="_blank"];
    n_analysis__spectrum_processing__MS2Deisotoper -> n_analysis__spectrum_processing__MS2NoiseFilter -> n_analysis__spectrum_processing__MzShiftFilter -> n_analysis__spectrum_processing__PrecursorMassFilter -> n_analysis__spectrum_processing__PrecursorRecalculator -> n_analysis__spectrum_processing__PrecursorRecalculatorDefault -> n_analysis__spectrum_processing__SpectrumListFactory -> n_analysis__spectrum_processing__SpectrumList_3D -> n_analysis__spectrum_processing__SpectrumList_ChargeFromIsotope -> n_analysis__spectrum_processing__SpectrumList_ChargeStateCalculator -> n_analysis__spectrum_processing__SpectrumList_Demux -> n_analysis__spectrum_processing__SpectrumList_DiaUmpire -> n_analysis__spectrum_processing__SpectrumList_Filter -> n_analysis__spectrum_processing__SpectrumList_IonMobility -> n_analysis__spectrum_processing__SpectrumList_LockmassRefiner -> n_analysis__spectrum_processing__SpectrumList_MZRefiner -> n_analysis__spectrum_processing__SpectrumList_MZWindow -> n_analysis__spectrum_processing__SpectrumList_MetadataFixer -> n_analysis__spectrum_processing__SpectrumList_PeakFilter -> n_analysis__spectrum_processing__SpectrumList_PeakPicker -> n_analysis__spectrum_processing__SpectrumList_PrecursorRecalculator -> n_analysis__spectrum_processing__SpectrumList_PrecursorRefine -> n_analysis__spectrum_processing__SpectrumList_ScanSummer -> n_analysis__spectrum_processing__SpectrumList_Smoother -> n_analysis__spectrum_processing__SpectrumList_Sorter -> n_analysis__spectrum_processing__SpectrumList_TitleMaker -> n_analysis__spectrum_processing__SpectrumList_ZeroSamplesFilter -> n_analysis__spectrum_processing__ThresholdFilter [style=invis, constraint=false];
  }
  subgraph cluster_analysis_peakdetect {
    label=<<b>peakdetect</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_analysis__peakdetect__FeatureDetector [label="FeatureDetector", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="MS1 feature (peakel) detector. NOT PORTED — research module.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/FeatureDetector.hpp", target="_blank"];
    n_analysis__peakdetect__FeatureDetectorPeakel [label="FeatureDetectorPeakel", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Peakel-based feature detector. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/FeatureDetectorPeakel.cpp", target="_blank"];
    n_analysis__peakdetect__FeatureDetectorSimple [label="FeatureDetectorSimple", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Greedy feature detector. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/FeatureDetectorSimple.cpp", target="_blank"];
    n_analysis__peakdetect__FeatureModeler [label="FeatureModeler", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Gaussian-mixture model fitter for features. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/FeatureModeler.cpp", target="_blank"];
    n_analysis__peakdetect__MZRTField [label="MZRTField", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="(m/z, rt) coordinate type. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/MZRTField.cpp", target="_blank"];
    n_analysis__peakdetect__Noise [label="Noise", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Noise estimation utilities. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/Noise.cpp", target="_blank"];
    n_analysis__peakdetect__PeakExtractor [label="PeakExtractor", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Extract peaks above a noise floor (feature-detector helper). NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakExtractor.cpp", target="_blank"];
    n_analysis__peakdetect__PeakFamilyDetector [label="PeakFamilyDetector", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Charge-state-aware peak family grouping. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakFamilyDetector.cpp", target="_blank"];
    n_analysis__peakdetect__PeakFamilyDetectorFT [label="PeakFamilyDetectorFT", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="FT-MS-specific peak family detector. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakFamilyDetectorFT.cpp", target="_blank"];
    n_analysis__peakdetect__PeakFinder [label="PeakFinder", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="IPeakDetector + CwtPeakDetector + LocalMaximumPeakDetector.&#10;Ported as Analysis/PeakPicking/IPeakDetector.cs + CwtPeakDetector.cs +&#10;LocalMaximumPeakDetector.cs. Reference test fixtures (CwtPeakDetectorReferenceTests)&#10;run cpp-generated peak data through the C# port for parity.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakFinder.cpp", target="_blank"];
    n_analysis__peakdetect__PeakFitter [label="PeakFitter", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Per-peak Gaussian/parabola fit. NOT PORTED — only feature-detector consumers use it.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakFitter.cpp", target="_blank"];
    n_analysis__peakdetect__PeakelGrower [label="PeakelGrower", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Time-extension of MS1 peaks across scans. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakelGrower.cpp", target="_blank"];
    n_analysis__peakdetect__PeakelPicker [label="PeakelPicker", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Peakel selection from candidate set. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/PeakelPicker.cpp", target="_blank"];
    n_analysis__peakdetect__msextract [label=<<s>msextract</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="CLI driver. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/peakdetect/msextract.cpp", target="_blank"];
    n_analysis__peakdetect__FeatureDetector -> n_analysis__peakdetect__FeatureDetectorPeakel -> n_analysis__peakdetect__FeatureDetectorSimple -> n_analysis__peakdetect__FeatureModeler -> n_analysis__peakdetect__MZRTField -> n_analysis__peakdetect__Noise -> n_analysis__peakdetect__PeakExtractor -> n_analysis__peakdetect__PeakFamilyDetector -> n_analysis__peakdetect__PeakFamilyDetectorFT -> n_analysis__peakdetect__PeakFinder -> n_analysis__peakdetect__PeakFitter -> n_analysis__peakdetect__PeakelGrower -> n_analysis__peakdetect__PeakelPicker -> n_analysis__peakdetect__msextract [style=invis, constraint=false];
  }
  subgraph cluster_analysis_demux {
    label=<<b>demux</b>>;
    style="rounded,dashed";
    color="#888";
    fontname="Segoe UI";
    fontsize=11;
    margin=10;
    rank=same;
    n_analysis__demux__CubicHermiteSpline [label="CubicHermiteSpline", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Cubic Hermite interpolation. NOT PORTED — no current consumer in the demux path.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/CubicHermiteSpline.cpp", target="_blank"];
    n_analysis__demux__DemuxDataProcessingStrings [label="DemuxDataProcessingStrings", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="String constants for DataProcessing entries. Ported inline into DemuxHelpers.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxDataProcessingStrings.hpp", target="_blank"];
    n_analysis__demux__DemuxDebugReader [label=<<s>DemuxDebugReader</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Debug snapshot reader. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxDebugReader.cpp", target="_blank"];
    n_analysis__demux__DemuxDebugWriter [label=<<s>DemuxDebugWriter</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Debug snapshot writer. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxDebugWriter.cpp", target="_blank"];
    n_analysis__demux__DemuxHelpers [label="DemuxHelpers", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Helper functions for demux scoring/sorting. Ported as Analysis/Demux/DemuxHelpers.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxHelpers.cpp", target="_blank"];
    n_analysis__demux__DemuxSolver [label="DemuxSolver", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Non-negative least-squares (NNLS) solver for DIA demultiplexing.&#10;Ported as Analysis/Demux/DemuxSolver.cs + Nnls.cs (~200 LOC; cpp-bit-equivalent&#10;active-set solver). Optimized with span-based memory access for 4-8x speedup vs&#10;naïve port.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxSolver.cpp", target="_blank"];
    n_analysis__demux__DemuxTypes [label="DemuxTypes", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Common demux types (DemuxWindow, DemuxIsolationWindow). Folded into Analysis/Demux/PrecursorMaskCodec.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/DemuxTypes.hpp", target="_blank"];
    n_analysis__demux__EnumConstantNotPresentException [label=<<s>EnumConstantNotPresentException</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Trivial exception type. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/EnumConstantNotPresentException.hpp", target="_blank"];
    n_analysis__demux__FSDemux [label=<<s>FSDemux</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Filesystem-backed demux debug mode. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/FSDemux.cpp", target="_blank"];
    n_analysis__demux__IDemultiplexer [label="IDemultiplexer", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="IDemultiplexer interface. Ported as Analysis/Demux/IDemultiplexer.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/IDemultiplexer.hpp", target="_blank"];
    n_analysis__demux__IInterpolation [label="IInterpolation", fillcolor="#f5a8a8", color="#a02020", fontcolor="#3d0a0a", tooltip="Generic interpolator interface. NOT PORTED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/IInterpolation.hpp", target="_blank"];
    n_analysis__demux__IPrecursorMaskCodec [label="IPrecursorMaskCodec", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="Header-only interface. Subsumed by PrecursorMaskCodec.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/IPrecursorMaskCodec.hpp", target="_blank"];
    n_analysis__demux__MSXDemultiplexer [label="MSXDemultiplexer", fillcolor="#9ee5a3", color="#2c7a32", fontcolor="#0a3d10", tooltip="MSX demultiplexer (Thermo MS2 multiplexing). Ported as Analysis/Demux/MsxDemultiplexer.cs.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/MSXDemultiplexer.cpp", target="_blank"];
    n_analysis__demux__MatrixIO [label=<<s>MatrixIO</s>>, fillcolor="#dcdcdc", color="#888888", fontcolor="#555555", tooltip="Eigen matrix I/O for debug snapshots. SKIPPED.", href="https://github.com/ProteoWizard/pwiz/blob/master/pwiz/analysis/demux/MatrixIO.cpp", target="_blank"];
