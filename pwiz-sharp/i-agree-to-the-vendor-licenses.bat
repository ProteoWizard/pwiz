@echo off
rem One-click opt-in for vendor SDKs. Writes Directory.Build.user.props with
rem <IAgreeToVendorLicenses>true</IAgreeToVendorLicenses>, which Directory.Build.props
rem imports if present. Equivalent to passing -p:IAgreeToVendorLicenses=true on every
rem dotnet/MSBuild invocation. The .user.props file is gitignored.
rem
rem Re-running this script is a no-op (idempotent overwrite).

setlocal
set "TARGET=%~dp0Directory.Build.user.props"

> "%TARGET%" echo ^<Project^>
>>"%TARGET%" echo   ^<!-- Generated by i-agree-to-the-vendor-licenses.bat. Do not check in. --^>
>>"%TARGET%" echo   ^<PropertyGroup^>
>>"%TARGET%" echo     ^<IAgreeToVendorLicenses^>true^</IAgreeToVendorLicenses^>
>>"%TARGET%" echo   ^</PropertyGroup^>
>>"%TARGET%" echo ^</Project^>

echo Wrote %TARGET%
echo Vendor SDKs (Thermo / Bruker / Waters / Agilent / Sciex) will now be enabled in
echo Visual Studio + dotnet builds. Delete the file to opt back out.
endlocal
