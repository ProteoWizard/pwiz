<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Pwiz.Tools.BiblioSpec.BlibBuild</RootNamespace>
    <AssemblyName>BlibBuild</AssemblyName>
    <Description>BlibBuild CLI tool. Port of pwiz_tools/BiblioSpec/src/BlibBuild.cpp.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\BiblioSpec\BiblioSpec.csproj" />

    <!-- Vendor SDK-backed readers. BlibBuild needs to open .baf / .raw / .wiff / .lcd / etc.
         when a search-results file (pep.xml, msms.txt, …) references a vendor-format spectrum
         file. The vendor projects can't live in the core Pwiz.Data.MsData assembly without
         dragging the native SDKs into every consumer, so they're registered at startup
         (see Program.cs RegisterVendorReaders). -->
    <ProjectReference Include="..\..\..\..\pwiz\src\Vendor\Bruker\Bruker.csproj" />
    <ProjectReference Include="..\..\..\..\pwiz\src\Vendor\Sciex\Sciex.csproj" />
    <ProjectReference Include="..\..\..\..\pwiz\src\Vendor\Shimadzu\Shimadzu.csproj" />
    <ProjectReference Include="..\..\..\..\pwiz\src\Vendor\Thermo\Thermo.csproj" />
  </ItemGroup>

  <!-- cpp parity: MaxQuantReader.cpp:177 — when no modifications.xml lives next to the
       msms.txt input, fall back to the one shipped next to the BlibBuild exe. Copy the
       cpp tree's shipping file into the BlibBuild output directory so the C# port has
       the same fallback. -->
  <ItemGroup>
    <None Include="..\..\..\..\..\pwiz_tools\BiblioSpec\src\modifications.xml"
          Link="modifications.xml"
          Condition="Exists('..\..\..\..\..\pwiz_tools\BiblioSpec\src\modifications.xml')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
