<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.1" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\BiblioSpec\BiblioSpec.csproj" />
  </ItemGroup>

  <!-- The 4 CLI tools (BlibBuild / BlibFilter / BlibSearch / BlibToMs2) are
       process-exec'd by ExecuteBlib.cs, but the tools' csprojs aren't
       reference-able directly (they'd pull in main() entry points). We
       depend on them via the build order — tcbuild builds them before this
       test project runs. The TC build pipeline guarantees they exist; for
       local runs the tests Inconclusive-skip when missing. -->

  <!-- The MascotShim smoke tests reference internal types from BiblioSpec
       (MascotShimInterop, MascotResult) that are themselves gated on
       <MascotSupport>. Mirror the gate here so the test file doesn't fail
       to compile when MascotSupport=false. -->
  <PropertyGroup>
    <MascotSupport Condition="'$(MascotSupport)' == ''">true</MascotSupport>
  </PropertyGroup>
  <ItemGroup Condition="'$(MascotSupport)' != 'true'">
    <Compile Remove="MascotShimSmokeTests.cs" />
  </ItemGroup>

</Project>
