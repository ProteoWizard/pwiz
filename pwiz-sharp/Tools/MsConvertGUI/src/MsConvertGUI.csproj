<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <RootNamespace>MSConvertGUI</RootNamespace>
    <AssemblyName>MSConvertGUI-sharp</AssemblyName>
    <Description>Port of pwiz_tools/MSConvertGUI to pwiz-sharp. WinForms front-end on top of pwiz-sharp's MsConvert pipeline.</Description>

    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Resources\SpectrumConverter.ico</ApplicationIcon>

    <!-- Vendor SDKs (specifically Thermo) need en-US culture; matching MsConvert.csproj. -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <EnableUnsafeBinaryFormatterSerialization>true</EnableUnsafeBinaryFormatterSerialization>

    <!-- Near-verbatim port of legacy WinForms code (pre-nullable C#). Same posture as SeeMS. -->
    <Nullable>disable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS0618;CS1591;CS8981;CA1416;CA1822;CA1031;CA1051;CA1715;CA2200;CA1825;NU1701;SYSLIB0003;SYSLIB0011;SYSLIB0050;SYSLIB0051</NoWarn>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <AnalysisLevel>none</AnalysisLevel>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\pwiz\src\Util\Util.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Common\Common.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\MsData\MsData.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Analysis\Analysis.csproj" />
    <ProjectReference Include="..\..\Commandline\MsConvert\src\MsConvert.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\StlContainers\StlContainers.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Common\Vendor.Common.csproj" />
    <ProjectReference Include="CustomDataSourceDialog\CustomDataSourceDialog.csproj" />
  </ItemGroup>


  <!-- CustomDataSourceDialog has its own .csproj (so its embedded resources are named
       "CustomDataSourceDialog.Properties.Resources.resources" rather than getting the
       MSConvertGUI namespace prefix). Exclude its files from this project's default globs. -->
  <ItemGroup>
    <Compile Remove="CustomDataSourceDialog\**\*.cs" />
    <EmbeddedResource Remove="CustomDataSourceDialog\**\*.resx" />
    <None Remove="CustomDataSourceDialog\**\*.settings" />
  </ItemGroup>

  <!-- Vendor support is opt-in (mirrors MsConvert.csproj). Without -p:IAgreeToVendorLicenses=true,
       vendor projects compile in NO_VENDOR_SUPPORT mode and Reader.Read throws clearly. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Thermo\Thermo.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Bruker\Bruker.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Waters\Waters.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Agilent\Agilent.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Sciex\Sciex.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Shimadzu\Shimadzu.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\UIMF\UIMF.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\UNIFI\UNIFI.csproj" />
    <ProjectReference Include="..\..\..\pwiz\src\Vendor\Mobilion\Mobilion.csproj" />
  </ItemGroup>

  <!-- First-pass shell: exclude UNIFI auth dialogs that need IdentityModel + Newtonsoft.Json
       NuGet packages we haven't pulled in yet. The Credentials nested type that MainForm.cs
       references is stubbed by Compat.cs. Re-enable these when UNIFI auth ports to pwiz-sharp.
  -->
  <ItemGroup>
    <Compile Remove="LoginForm.cs" />
    <Compile Remove="LoginForm.Designer.cs" />
    <EmbeddedResource Remove="LoginForm.resx" />

    <Compile Remove="UnifiBrowserForm.cs" />
    <Compile Remove="UnifiBrowserForm.Designer.cs" />
    <EmbeddedResource Remove="UnifiBrowserForm.resx" />
  </ItemGroup>

</Project>
