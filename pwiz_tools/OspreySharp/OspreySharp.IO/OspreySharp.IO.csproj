<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>pwiz.OspreySharp.IO</RootNamespace>
    <AssemblyName>OspreySharp.IO</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="OspreySharp.Test" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Parquet.Net" Version="3.10.0" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.118" />
  </ItemGroup>

  <!-- net472 needs System.Memory explicitly; net8 has it built in. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <PackageReference Include="System.Memory" Version="4.5.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OspreySharp.Core\OspreySharp.Core.csproj" />
  </ItemGroup>

</Project>
