<Project Sdk="Microsoft.NET.Sdk">

  <!-- SkylineNightly - WinForms app that runs the nightly test suite and reports results.
       Multi-target net472;net8.0-windows (classic was net472/x86). net472 keeps the exact on-disk
       HintPath DLLs (DotNetZip, the legacy net40 ClrMD, TaskScheduler from SkylineTester) + the WCF
       framework assembly; net8 pulls the managed NuGet equivalents. The vestigial System.Deployment
       reference (no ClickOnce usage) is dropped. Only one code change was needed: the ClrMD
       DataTarget.AttachToProcess signature differs between the net40 and modern packages (see
       LogFileMonitor.cs). The IEndTimeSetter IPC is a WCF *client* (ChannelFactory) - it works on net8
       via the System.ServiceModel.NetNamedPipe package (no CoreWCF needed for the client side). -->
  <PropertyGroup>
    <ProjectGuid>{32A40878-3053-4FFA-96C1-23FC27D46B65}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>SkylineNightly</RootNamespace>
    <AssemblyName>SkylineNightly</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <!-- Non-.resx embedded resource (a SkylineTester run config); the SDK glob doesn't pick it up. -->
    <EmbeddedResource Include="SkylineNightly.skytr" />
  </ItemGroup>

  <!-- net8: managed NuGet equivalents of the legacy on-disk DLLs + the WCF client. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="DotNetZip" Version="1.16.0" />
    <PackageReference Include="Microsoft.Diagnostics.Runtime" Version="3.1.512801" />
    <PackageReference Include="TaskScheduler" Version="2.11.0" />
    <PackageReference Include="System.ServiceModel.NetNamedPipe" Version="8.0.0" />
  </ItemGroup>

  <!-- net472: the exact on-disk DLLs + the framework assemblies the SDK doesn't auto-add. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="DotNetZip"><HintPath>..\..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath></Reference>
    <Reference Include="Microsoft.Diagnostics.Runtime"><HintPath>..\..\Shared\Lib\Microsoft.Diagnostics.Runtime\lib\net40\Microsoft.Diagnostics.Runtime.dll</HintPath></Reference>
    <Reference Include="Microsoft.Win32.TaskScheduler"><HintPath>..\SkylineTester\Microsoft.Win32.TaskScheduler.dll</HintPath></Reference>
    <Reference Include="System.Net.Http" />
    <Reference Include="System.ServiceModel" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>

</Project>
