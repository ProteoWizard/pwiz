<Project Sdk="Microsoft.NET.Sdk">

  <!-- TestUtil - Skyline test support library (base classes + helpers).
       Multi-target net472 + net8.0-windows to match Skyline.csproj.
       No [TestClass] entries here; consumers (TestData, Test, etc.) supply
       the test adapter. MSTest.TestFramework is still needed for the
       Assert / TestContext types referenced by AbstractUnitTest, AssertEx. -->
  <PropertyGroup>
    <ProjectGuid>{1A76F2B4-353A-4BCF-9D15-70D4B387E480}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.SkylineTestUtil</RootNamespace>
    <AssemblyName>TestUtil</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903;SYSLIB0011</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
  </ItemGroup>

  <!-- SDK glob picks up code + .resx by default, but Skyline_*.xsd schema files,
       .view report layouts, and .skyr report definitions are loaded at test time
       via GetManifestResourceStream - must be embedded explicitly. Without these
       XmlValidationTest, LocalizedResourcesTest, TestCurrentXmlFormat, and
       CheckReportCompatibility fail with "resource not found in assembly". -->
  <ItemGroup>
    <EmbeddedResource Include="Schemas\**\*.xsd" />
    <EmbeddedResource Include="minimal.sky.view" />
    <EmbeddedResource Include="CheckReportCompatibility.skyr" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\CommonFileDialogs\CommonFileDialogs.csproj" />
    <ProjectReference Include="..\..\Shared\CommonMsData\CommonMsData.csproj" />
    <ProjectReference Include="..\..\Shared\Common\Common.csproj" />
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\Shared\PortableUtil\PortableUtil.csproj" />
    <ProjectReference Include="..\..\Shared\MSGraph\MSGraph.csproj" />
    <ProjectReference Include="..\..\Shared\ProteomeDb\ProteomeDb.csproj" />
    <ProjectReference Include="..\..\Shared\ProteowizardWrapper\ProteowizardWrapper.csproj" />
    <ProjectReference Include="..\..\Shared\zedgraph\ZedGraph.csproj" />
    <ProjectReference Include="..\Skyline.csproj" />
    <ProjectReference Include="..\TestRunnerLib\TestRunnerLib.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="Accessibility" />
    <Reference Include="System.Net.Http" />
    <Reference Include="DigitalRune.Windows.Docking"><HintPath>..\..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath></Reference>
    <Reference Include="Excel.4.5"><HintPath>..\..\Shared\Lib\ExcelDataReader\Excel.4.5.dll</HintPath></Reference>
    <Reference Include="DotNetZip"><HintPath>..\..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath></Reference>
    <Reference Include="Google.Protobuf"><HintPath>..\..\Shared\Lib\Google.Protobuf.dll</HintPath></Reference>
    <Reference Include="Grpc.Core"><HintPath>..\..\Shared\Lib\Grpc.Core.dll</HintPath></Reference>
    <Reference Include="Grpc.Core.Api"><HintPath>..\..\Shared\Lib\Grpc.Core.Api.dll</HintPath></Reference>
    <Reference Include="JetBrains.Annotations"><HintPath>..\..\Shared\Lib\JetBrains.Annotations.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Microsoft.Diagnostics.Runtime"><HintPath>..\..\Shared\Lib\Microsoft.Diagnostics.Runtime\lib\net40\Microsoft.Diagnostics.Runtime.dll</HintPath></Reference>
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="System.Data.SQLite"><HintPath>..\..\..\libraries\SQLite\$(Platform)\System.Data.SQLite.dll</HintPath></Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Google.Protobuf" Version="3.27.3" />
    <PackageReference Include="Grpc.Net.Client" Version="2.66.0" />
    <PackageReference Include="DotNetZip" Version="1.16.0" />
    <PackageReference Include="JetBrains.Annotations" Version="2024.3.0" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <!-- Modern ExcelDataReader (namespace ExcelDataReader) replaces the Framework-only
         Excel.4.5 v2.1 fork (namespace Excel), which NREs in AsDataSet() at runtime on net8.
         The .DataSet package supplies the AsDataSet() extension; System.Text.Encoding.CodePages
         supplies CodePagesEncodingProvider, required to read legacy .xls (BIFF) files on net8. -->
    <PackageReference Include="ExcelDataReader" Version="3.7.0" />
    <PackageReference Include="ExcelDataReader.DataSet" Version="3.7.0" />
    <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
    <Reference Include="Microsoft.Diagnostics.Runtime">
      <HintPath>..\..\Shared\Lib\Microsoft.Diagnostics.Runtime\lib\net40\Microsoft.Diagnostics.Runtime.dll</HintPath>
    </Reference>
    <Reference Include="DigitalRune.Windows.Docking">
      <HintPath>..\..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
