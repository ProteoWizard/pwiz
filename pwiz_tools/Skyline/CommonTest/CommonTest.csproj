<Project Sdk="Microsoft.NET.Sdk">

  <!-- CommonTest - Skyline shared test library (DataBinding, FastaImporter,
       PrecisionNumber, SqliteOperations, ViewSpec). Multi-target
       net472 + net8.0-windows to match Test/TestData porting cadence. -->
  <PropertyGroup>
    <ProjectGuid>{3F077244-13E5-4815-BA55-31F030042E06}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>CommonTest</RootNamespace>
    <AssemblyName>CommonTest</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Legacy csproj listed "FastaImporterWebData.json" but the actual filename
         on disk is "FastaImporterTestWebData.json" (has been for years). MSBuild
         silently ignored the missing file; the dotnet SDK's Copy target errors
         instead, so use the correct name. -->
    <None Include="FastaImporterTestWebData.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="FastaImporterTestExpected.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Common\Common.csproj" />
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\Shared\ProteomeDb\ProteomeDb.csproj" />
    <ProjectReference Include="..\TestUtil\TestUtil.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="JetBrains.Annotations"><HintPath>..\..\Shared\Lib\JetBrains.Annotations.dll</HintPath></Reference>
    <Reference Include="Microsoft.VisualStudio.QualityTools.UnitTestFramework" />
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="System.Data.SQLite"><HintPath>..\..\..\libraries\SQLite\$(Platform)\System.Data.SQLite.dll</HintPath></Reference>
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.2.0" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <PackageReference Include="JetBrains.Annotations" Version="2024.3.0" />
  </ItemGroup>

</Project>
