<Project Sdk="Microsoft.NET.Sdk">

  <!-- SkylineTester - WinForms test-harness GUI (run tests / nightly / quality, build Skyline, zip
       installers, chart memory). Multi-target net472 + net8.0-windows; the classic project was a
       v4.7.2 WinExe. net8 notes: DotNetZip + Microsoft.Win32.TaskScheduler come from NuGet (net472
       keeps the legacy on-disk HintPath DLLs); the EnvDTE "open the clicked source line in a running
       Visual Studio" feature is net472-only VS COM automation (see TabOutput.cs #if NET472 - net8
       falls back to launching devenv.exe); dropped the vestigial System.Deployment / System.ServiceModel
       / System.Management references (no code references them). -->
  <PropertyGroup>
    <ProjectGuid>{65E16E9D-71FC-40D1-B3FF-AD16BEFF9AF4}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>SkylineTester</RootNamespace>
    <AssemblyName>SkylineTester</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ApplicationIcon>SkylineTester.ico</ApplicationIcon>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <!-- Stale local copy; the classic project excluded it and used TestRunnerLib.FormLookup (which
       has GetTest). The SDK compile-glob would otherwise pick it up and shadow the real one. -->
  <ItemGroup>
    <Compile Remove="FormLookup.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\Shared\zedgraph\ZedGraph.csproj" />
    <ProjectReference Include="..\Skyline.csproj" />
    <ProjectReference Include="..\TestRunnerLib\TestRunnerLib.csproj" />
    <ProjectReference Include="..\TestUtil\TestUtil.csproj" />
  </ItemGroup>

  <!-- net8: managed NuGet equivalents of the legacy HintPath DLLs + the settings config provider -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="DotNetZip" Version="1.16.0" />
    <PackageReference Include="TaskScheduler" Version="2.11.0" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

  <!-- net472: the legacy on-disk DLLs + EnvDTE VS COM automation the net8 path drops -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="EnvDTE, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <EmbedInteropTypes>True</EmbedInteropTypes>
    </Reference>
    <Reference Include="DotNetZip">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>..\..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Win32.TaskScheduler">
      <HintPath>.\Microsoft.Win32.TaskScheduler.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <None Include="Run files\BuildSkyline32.skytr" />
    <None Include="Run files\BuildSkyline64.skytr" />
    <None Include="Run files\OnePassQuality.skytr" />
    <None Include="Run files\RegenerateFormsList.skytr" />
    <None Include="Run files\SubmitCheck.skytr" />
    <None Include="Run files\TutorialsDemo.skytr" />
  </ItemGroup>

</Project>
