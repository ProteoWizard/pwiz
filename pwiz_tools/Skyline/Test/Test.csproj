    <PackageReference Include="NHibernate" Version="5.5.2" />
    <PackageReference Include="Iesi.Collections" Version="4.0.5" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
  </ItemGroup>

  <!-- CmdLineAssociateProteinsTest shells out to SkylineCmd.exe, which it locates next to
       Skyline-daily.dll in this project's output. SkylineCmd is built via Skyline's
       ProjectReference; copy its output (exe + runtime files) into this project's output after
       Build. A static Content glob would miss it on a clean build (its bin is produced during
       this build). -->
  <Target Name="_DeploySkylineCmd"
          Condition="'$(TargetFramework)' == 'net8.0-windows'"
          AfterTargets="Build">
    <ItemGroup>
      <_SkylineCmdOutput Include="..\SkylineCmd\bin\$(Configuration)\net8.0-windows\SkylineCmd.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_SkylineCmdOutput)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="'@(_SkylineCmdOutput)' != ''" />
  </Target>

</Project>
