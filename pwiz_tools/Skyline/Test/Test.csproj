<Project Sdk="Microsoft.NET.Sdk">

  <!-- Test - Skyline main unit-test MSTest assembly. Multi-target
       net472 + net8.0-windows to match Skyline / TestData porting cadence.
       Enumerates EmbeddedResource + None items explicitly (mirroring the
       legacy csproj) because SDK default globs don't pick up .sky / .skyr /
       .csv / .zip / .tsv / .blib. Compile items ARE auto-globbed. -->
  <PropertyGroup>
    <ProjectGuid>{E0FA262A-744E-4D98-A43F-4723A4D95827}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.SkylineTest</RootNamespace>
    <AssemblyName>Test</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903;SYSLIB0011</NoWarn>
    <EnableDefaultNoneItems>false</EnableDefaultNoneItems>
  </PropertyGroup>

  <!-- ProtocolBuffers\tmp\ is the transient dir generatecode.bat emits to
       before diffing + copying into GeneratedCode. It's not meant to be
       compiled - exclude it before SDK globs it in. -->
  <ItemGroup>
    <Compile Remove="ProtocolBuffers\tmp\**\*" />
  </ItemGroup>

  <!-- AssortResources source files linked in from Executables\DevTools\.
       CodeInspectionTest.cs uses AssortResources.ResourceAssorter for self-
       healing resource-file sorting. Legacy csproj linked these to avoid
       building AssortResources as a separate project. -->
  <ItemGroup>
    <Compile Include="..\Executables\DevTools\AssortResources\CsProjFile.cs" Link="AssortResources\CsProjFile.cs" />
    <Compile Include="..\Executables\DevTools\AssortResources\ResourceAssorter.cs" Link="AssortResources\ResourceAssorter.cs" />
    <Compile Include="..\Executables\DevTools\AssortResources\ResourceFile.cs" Link="AssortResources\ResourceFile.cs" />
    <Compile Include="..\Executables\DevTools\AssortResources\ResourceIdentifiers.cs" Link="AssortResources\ResourceIdentifiers.cs" />
    <Compile Include="..\Executables\DevTools\AssortResources\ResourceReference.cs" Link="AssortResources\ResourceReference.cs" />
  </ItemGroup>

  <!-- protoc-generated code lives under ProtocolBuffers\GeneratedCode\.
       Auto-globbed by the SDK, but the .cs file has to exist BEFORE the
       compile step or the build errors on missing types (e.g.
       LegacySkylineDocumentProto). Run generatecode.bat before compile. -->
  <Target Name="TestGenerateProtobufCode" BeforeTargets="BeforeCompile" Inputs="ProtocolBuffers\LegacySkylineDocumentProto.proto" Outputs="ProtocolBuffers\GeneratedCode\LegacySkylineDocumentProto.cs">
    <Exec Command="&quot;$(ProjectDir)ProtocolBuffers\generatecode.bat&quot;" WorkingDirectory="$(ProjectDir)ProtocolBuffers" />
  </Target>

  <!-- Test fixture zips + a couple loose files that live next to the .cs
       sources. All need to land in the output dir so AbstractUnitTest can
       find them via GetTestPath. -->
  <ItemGroup>
    <None Include="ChromatogramExporterTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="CommandLineAssayImportTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="CommandLineImportAnnotationsTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="CommandLineMProphetTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="DecoysTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="DocLoadLibraryTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ElibQuantifiableTransitionTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="FullScanPrecursor.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="LibraryRankedSpectrumInfoSpeedTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="modmatch.sky" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ModMatch.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="MProphetResultsHandlerTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="MProphetScoringModelTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="OnDemandFeatureCalculatorTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="PeakBoundaryTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="PeakGroupIntegratorTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Proteome\ProteomeDbTest.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ProtocolBuffers\generatecode.bat" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ProtocolBuffers\LegacySkylineDocumentProto.proto" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

