    <ProjectReference Include="..\CommonTest\CommonTest.csproj" />
    <ProjectReference Include="..\Skyline.csproj" />
    <ProjectReference Include="..\SkylineTool\SkylineTool.csproj" />
    <ProjectReference Include="..\TestRunnerLib\TestRunnerLib.csproj" />
    <ProjectReference Include="..\TestUtil\TestUtil.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="Google.Protobuf"><HintPath>..\..\Shared\Lib\Google.Protobuf.dll</HintPath></Reference>
    <Reference Include="HtmlAgilityPack"><HintPath>..\..\Shared\Lib\HtmlAgilityPack.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\Shared\Lib\log4net.dll</HintPath></Reference>
