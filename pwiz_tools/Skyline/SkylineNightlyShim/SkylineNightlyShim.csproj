<Project Sdk="Microsoft.NET.Sdk">

  <!-- SkylineNightlyShim - tiny console wrapper that updates the local SkylineNightly.exe from the
       build artifacts, then launches it. Multi-target net472;net8.0. Pure console/HTTP/zip (no
       WinForms/WCF), so the net8 side is plain net8.0. Shares TeamCityNightlyAuth from SkylineNightly
       by linking the file (not a project reference - the shim runs SkylineNightly.exe as a process). -->
  <PropertyGroup>
    <ProjectGuid>{3C7F5209-6507-42C5-80CE-472AE6A51CD1}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>SkylineNightlyShim</RootNamespace>
    <AssemblyName>SkylineNightlyShim</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\SkylineNightly\TeamCityNightlyAuth.cs">
      <Link>TeamCityNightlyAuth.cs</Link>
    </Compile>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="DotNetZip" Version="1.16.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="DotNetZip"><HintPath>..\..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath></Reference>
    <Reference Include="System.Net.Http" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>

</Project>
