<Project Sdk="Microsoft.NET.Sdk">

  <!-- SkylineCmd - thin launcher that reflects into Skyline(-daily)'s Program.Main
       for command-line runs. Standalone: it takes no reference on Skyline and loads
       it at runtime from its own directory (see Program.GetMainFunction). Multi-target
       net472 + net8.0-windows; on net8 the managed entry point is Skyline-daily.dll
       (the .exe there is a native apphost). -->
  <PropertyGroup>
    <ProjectGuid>{FA16A0EF-EDF7-4515-BD93-44BADD7AB98A}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.SkylineCmd</RootNamespace>
    <AssemblyName>SkylineCmd</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- SkylineCmd itself is console-only, but it loads Skyline (a WinForms app) at
         runtime, so it must run on the Windows Desktop runtime (Microsoft.WindowsDesktop.App)
         so System.Windows.Forms resolves. -->
    <UseWindowsForms>true</UseWindowsForms>
    <IsPackable>false</IsPackable>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

</Project>
