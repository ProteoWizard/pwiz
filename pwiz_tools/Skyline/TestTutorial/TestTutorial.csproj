<Project Sdk="Microsoft.NET.Sdk">

  <!-- TestTutorial - Skyline tutorial (UI-driving) MSTest assembly. Multi-target
       net472 + net8.0-windows. No .resx/designer; test fixtures are flat *.zip files
       copied to output. Compile items are auto-globbed. -->
  <PropertyGroup>
    <ProjectGuid>{6FCD5F27-637B-499A-BB66-F74D5FBBD500}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.SkylineTestTutorial</RootNamespace>
    <AssemblyName>TestTutorial</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903;SYSLIB0011</NoWarn>
    <EnableDefaultNoneItems>false</EnableDefaultNoneItems>
  </PropertyGroup>

  <!-- Fixtures land next to the assembly for AbstractUnitTest.GetTestPath. -->
  <ItemGroup>
    <None Include="*.zip" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ExistingQuant_excel.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\BiblioSpec\BiblioSpec.csproj" />
    <ProjectReference Include="..\..\Shared\CommonFileDialogs\CommonFileDialogs.csproj" />
    <ProjectReference Include="..\..\Shared\CommonMsData\CommonMsData.csproj" />
    <ProjectReference Include="..\..\Shared\Common\Common.csproj" />
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\Shared\MSGraph\MSGraph.csproj" />
    <ProjectReference Include="..\..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\..\Shared\ProteomeDb\ProteomeDb.csproj" />
    <ProjectReference Include="..\..\Shared\ProteowizardWrapper\ProteowizardWrapper.csproj" />
    <ProjectReference Include="..\..\Shared\zedgraph\ZedGraph.csproj" />
    <ProjectReference Include="..\Skyline.csproj" />
    <ProjectReference Include="..\TestUtil\TestUtil.csproj" />
  </ItemGroup>

  <!-- net8: managed test + support packages; DigitalRune docking, DotNetZip, Grpc,
       ServiceModel etc. flow transitively through the Skyline/Shared ProjectReferences. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.2.0" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="MathNet.Numerics" Version="4.15.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <!-- Raw assembly references don't flow transitively through Skyline's ProjectReference,
         so reference DigitalRune (docking types used by the graph forms these tests drive) here too. -->
    <Reference Include="DigitalRune.Windows.Docking"><HintPath>..\..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath></Reference>
  </ItemGroup>

  <!-- net472: legacy assembly references, kept verbatim so the existing build path is unchanged. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="DigitalRune.Windows.Docking"><HintPath>..\..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath></Reference>
    <Reference Include="DotNetZip"><HintPath>..\..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath></Reference>
    <Reference Include="JetBrains.Annotations"><HintPath>..\..\Shared\Lib\JetBrains.Annotations.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Microsoft.VisualStudio.QualityTools.UnitTestFramework" />
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
  </ItemGroup>

</Project>
