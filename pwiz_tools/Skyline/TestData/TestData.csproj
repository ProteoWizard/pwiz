<Project Sdk="Microsoft.NET.Sdk">

  <!-- TestData - Skyline "test data" MSTest assembly. Multi-target
       net472 + net8.0-windows. The net8 run is what surfaces pwiz-sharp
       data-parity regressions vs. the legacy pwiz C++/CLI path. -->
  <PropertyGroup>
    <ProjectGuid>{F1A6D016-7608-4A7B-8D68-FB32B8344D4B}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.SkylineTestData</RootNamespace>
    <AssemblyName>TestData</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
    <!-- Set explicitly (not just via Microsoft.NET.Test.Sdk, which we reference only under
         the net8.0-windows condition) so IsTestProject is in scope for restore and for
         Directory.Build.targets' test-only TeamCity logger reference. -->
    <IsTestProject>true</IsTestProject>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903;SYSLIB0011</NoWarn>
    <!-- Test .zip / .data / .sky fixtures live alongside the .cs files.
         They must ship to the output dir so AbstractUnitTest.GetTestPath can
         locate them without walking back into the source tree. -->
    <EnableDefaultNoneItems>false</EnableDefaultNoneItems>
  </PropertyGroup>

  <!-- Fixture data next to the test .cs - copy to output. Exclude bin/obj: with
       EnableDefaultNoneItems=false these globs don't inherit the SDK's default output
       exclusion, so "**\*.zip" would otherwise re-copy bin's own fixtures into
       bin\...\bin\...\ on every incremental build (deep nesting that fills the disk). -->
  <ItemGroup>
    <None Include="**\*.zip" Exclude="bin\**;obj\**" CopyToOutputDirectory="PreserveNewest" />
    <None Include="**\*.data" Exclude="bin\**;obj\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Results\MultiLabelCustomReports.skyr" />
    <EmbeddedResource Include="Results\MultiLabelWithResults.sky" />
    <EmbeddedResource Include="Results\PeptideQuantifierTest.sky" />
    <EmbeddedResource Include="Results\HeavyVariable.sky" />
    <EmbeddedResource Include="Results\MultiLabel.sky" />
  </ItemGroup>

  <ItemGroup>
    <!-- SkylineRunner's ErrorChecker.cs is linked in - same pattern as legacy. -->
    <Compile Include="..\Executables\SkylineRunner\ErrorChecker.cs" Link="ErrorChecker.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\BiblioSpec\BiblioSpec.csproj" />
    <ProjectReference Include="..\..\Shared\CommonFileDialogs\CommonFileDialogs.csproj" />
    <ProjectReference Include="..\..\Shared\CommonMsData\CommonMsData.csproj" />
    <ProjectReference Include="..\..\Shared\Common\Common.csproj" />
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\Shared\PortableUtil\PortableUtil.csproj" />
    <ProjectReference Include="..\..\Shared\MSGraph\MSGraph.csproj" />
    <ProjectReference Include="..\..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\..\Shared\ProteomeDb\ProteomeDb.csproj" />
    <ProjectReference Include="..\..\Shared\ProteowizardWrapper\ProteowizardWrapper.csproj" />
    <ProjectReference Include="..\Skyline.csproj" />
    <ProjectReference Include="..\TestUtil\TestUtil.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="Accessibility" />
    <Reference Include="DigitalRune.Windows.Docking" />
    <Reference Include="IdentityModel"><HintPath>..\..\Shared\Lib\IdentityModel.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="MathNet.Numerics"><HintPath>..\..\Shared\Lib\MathNet.Numerics.dll</HintPath></Reference>
    <Reference Include="Microsoft.VisualBasic" />
    <Reference Include="Microsoft.VisualStudio.QualityTools.UnitTestFramework" />
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="NHibernate"><HintPath>..\..\Shared\Lib\NHibernate\NHibernate.dll</HintPath></Reference>
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Deployment" />
    <Reference Include="System.Design" />
    <Reference Include="System.ServiceModel" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- These tests hit MsDataFileImpl surface that pwiz-sharp doesn't yet
         expose: ConfigInfo (DataFileMemoryLeakTest) and GetScanDescription
         (PwizFileInfoTest). Real pwiz-sharp gaps - excluded so the rest of
         the TestData suite can run and surface stub regressions. -->
    <Compile Remove="DataFileMemoryLeakTest.cs" />
    <Compile Remove="PwizFileInfoTest.cs" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.2.0" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="MathNet.Numerics" Version="4.15.0" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="NHibernate" Version="5.5.2" />
    <PackageReference Include="Iesi.Collections" Version="4.0.5" />
    <PackageReference Include="IdentityModel" Version="7.0.0" />
    <PackageReference Include="Microsoft.VisualBasic" Version="10.3.0" />
    <PackageReference Include="System.ServiceModel.Primitives" Version="8.0.0" />
    <Reference Include="DigitalRune.Windows.Docking">
      <HintPath>..\..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
