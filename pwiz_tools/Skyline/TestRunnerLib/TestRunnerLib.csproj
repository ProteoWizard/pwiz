<Project Sdk="Microsoft.NET.Sdk">

  <!-- TestRunnerLib - shared library for Skyline's TestRunner.exe.
       Converted to SDK multi-target so TestUtil / TestData can reference
       it under net8.0-windows too. -->
  <PropertyGroup>
    <ProjectGuid>{E3F0E34F-F9E6-4360-996F-E2054E4FA1AE}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>TestRunnerLib</RootNamespace>
    <AssemblyName>TestRunnerLib</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\CommonUtil\CommonUtil.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="TestRunnerFormLookup.csv" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="JetBrains.Annotations"><HintPath>..\..\Shared\Lib\JetBrains.Annotations.dll</HintPath></Reference>
    <Reference Include="JetBrains.Profiler.Api"><HintPath>..\..\Shared\Lib\Test\JetBrains.Profiler.Api.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Microsoft.VisualStudio.QualityTools.UnitTestFramework" />
    <Reference Include="System.Configuration" />
    <Reference Condition="'$(Platform)' == 'x86'" Include="TestDiagnostics">
      <HintPath>..\..\Shared\ProteowizardWrapper\obj\x86\TestDiagnostics.dll</HintPath>
    </Reference>
    <Reference Condition="'$(Platform)' == 'x64'" Include="TestDiagnostics">
      <HintPath>..\..\Shared\ProteowizardWrapper\obj\x64\TestDiagnostics.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- RunTests.cs / MemoryProfiler.cs / MiniDump.cs / InvokeSkyline.cs
         belong to the TestRunner.exe CLI driver, not to consumers of this
         library from `dotnet test`. TestDiagnostics.dll isn't available on
         net8, and MSTest 3.x's TestContext has a different abstract shape
         than the legacy VS UnitTestFramework, so drop the driver types. -->
    <PackageReference Include="JetBrains.Annotations" Version="2024.3.0" />
    <PackageReference Include="JetBrains.Profiler.Api" Version="1.4.0" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

</Project>
