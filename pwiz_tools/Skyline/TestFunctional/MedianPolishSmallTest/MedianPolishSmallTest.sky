        <view name="MedianPolishedAreas" rowsource="pwiz.Skyline.Model.Databinding.Entities.Peptide" sublist="" uimode="proteomic">
          <column name="" />
          <column name="ModifiedSequence.FullNames" />
          <column name="AverageMeasuredRetentionTime" />
          <column name="Results!*.Value.MedianPolishedArea" />
        </view>
        <layouts viewName="log2fold change" defaultLayout="Filter MS2">
          <layout name="Filter MS2">
            <rowFilter>
              <columnFilter column="MsLevel" opname="equals" operand="2" />
            </rowFilter>
          </layout>
        </layouts>
        <layouts viewName="MJM Protein Total Areas" defaultLayout="Sum of Peptide Areas">
          <layout name="Sum of Peptide Areas">
            <pivot>
              <rowHeader sourceColumn="Protein" />
              <rowHeader sourceColumn="ProteinDescription" />
              <rowHeader sourceColumn="ProteinGene" />
              <columnHeader sourceColumn="Replicate" />
              <value sourceColumn="NormalizedArea" op="Sum" />
            </pivot>
          </layout>
        </layouts>
      </views>
