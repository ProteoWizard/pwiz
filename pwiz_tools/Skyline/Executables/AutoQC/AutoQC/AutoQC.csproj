<Project Sdk="Microsoft.NET.Sdk">

  <!-- AutoQC - WinForms app that watches instrument folders and imports/uploads QC results.
       Multi-target net472;net8.0-windows. net472 keeps the exact on-disk HintPath DLLs + the
       framework assemblies; net8 pulls the managed NuGet equivalents (log4net, Newtonsoft.Json,
       ConfigurationManager, System.Management, ProtectedData). The ClickOnce (System.Deployment)
       auto-update path is #if NET472-guarded in Program.cs (net8 is never network-deployed), and the
       vestigial System.Configuration.Install / System.Web references are dropped. The startup-shortcut
       WScript.Shell (formerly an IWshRuntimeLibrary COMReference) is now late-bound dynamic COM in
       StartupManager.cs - dotnet build's .NET Core MSBuild can't run the tlbimp ResolveComReference task. -->
  <PropertyGroup>
    <ProjectGuid>{87D6B185-C2D3-48A9-95B3-A0F528F3F446}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>AutoQC</RootNamespace>
    <AssemblyName>AutoQC</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ApplicationIcon>AutoQC.ico</ApplicationIcon>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <ProjectReference Include="..\..\..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\..\..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\..\SharedBatch\SharedBatch\SharedBatch.csproj" />
  </ItemGroup>

  <!-- .ico embedded resources (loaded at runtime); .resx are picked up by the SDK glob. -->
  <ItemGroup>
    <EmbeddedResource Include="AutoQC.ico" />
    <EmbeddedResource Include="AutoQC-daily.ico" />
  </ItemGroup>

  <!-- net8: managed NuGet equivalents of the legacy on-disk DLLs + the settings/DPAPI providers. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

  <!-- net472: the exact on-disk DLLs + the framework assemblies the SDK doesn't auto-add. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="log4net"><HintPath>..\..\..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="System.Collections.Immutable"><HintPath>..\..\..\..\Shared\Lib\System.Collections.Immutable.dll</HintPath></Reference>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Configuration" />
    <Reference Include="System.Data" />
    <Reference Include="System.Deployment" />
    <Reference Include="System.Management" />
    <Reference Include="System.Security" />
  </ItemGroup>

  <!-- Config-file icon + report loaded at runtime -->
  <ItemGroup>
    <Content Include="AutoQC_configs.ico"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></Content>
    <Content Include="AutoQC_release.ico"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></Content>
    <Content Include="FileAcquisitionTime.skyr"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></Content>
  </ItemGroup>

  <!-- Bundled AutoQCStarter tray app + SkylineRunner shims + LaunchBatch launcher. Copied when the
       pre-built binaries are present; net8-native bundling of the ported shims is a follow-on. -->
  <ItemGroup>
    <Content Include="AutoQCStarter.exe" Condition="Exists('AutoQCStarter.exe')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\SharedBatch\LaunchBatch\obj\$(Configuration)\LaunchBatch.exe" Condition="Exists('..\..\SharedBatch\LaunchBatch\obj\$(Configuration)\LaunchBatch.exe')">
      <Link>LaunchBatch.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\SkylineRunner\Binaries\SkylineDailyRunner.exe" Condition="Exists('..\..\SkylineRunner\Binaries\SkylineDailyRunner.exe')">
      <Link>SkylineDailyRunner.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\SkylineRunner\Binaries\SkylineRunner.exe" Condition="Exists('..\..\SkylineRunner\Binaries\SkylineRunner.exe')">
      <Link>SkylineRunner.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="Properties\Settings.settings">
      <Generator>PublicSettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
