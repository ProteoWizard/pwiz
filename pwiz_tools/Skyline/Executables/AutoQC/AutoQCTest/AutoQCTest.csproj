<Project Sdk="Microsoft.NET.Sdk">

  <!-- AutoQCTest - MSTest unit + functional tests for AutoQC. Multi-target net472;net8.0-windows.
       net472 uses the GAC QualityTools framework + on-disk HintPath DLLs; net8 uses the MSTest NuGet
       stack (Microsoft.NET.Test.Sdk + MSTest.TestAdapter + MSTest.TestFramework) so `dotnet test` runs
       it. Vestigial CodedUI/UITesting references dropped. -->
  <PropertyGroup>
    <ProjectGuid>{4955F974-381E-4902-8BAD-BAC7174CFC9F}</ProjectGuid>
    <OutputType>Library</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>AutoQCTest</RootNamespace>
    <AssemblyName>AutoQCTest</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsTestProject>true</IsTestProject>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\..\..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\..\SharedBatch\SharedBatchTest\SharedBatchTest.csproj" />
    <ProjectReference Include="..\..\SharedBatch\SharedBatch\SharedBatch.csproj" />
    <ProjectReference Include="..\AutoQCStarter\AutoQCStarter.csproj" />
    <ProjectReference Include="..\AutoQC\AutoQC.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.2.0" />
    <PackageReference Include="MSTest.TestFramework" Version="3.2.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="log4net" Version="2.0.17" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="Microsoft.VisualStudio.QualityTools.UnitTestFramework" />
    <Reference Include="log4net"><HintPath>..\..\..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Configuration" />
  </ItemGroup>

  <ItemGroup>
    <None Include="App.config" />
  </ItemGroup>

</Project>
