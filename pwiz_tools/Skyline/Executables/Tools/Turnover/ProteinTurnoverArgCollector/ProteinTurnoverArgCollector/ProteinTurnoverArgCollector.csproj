<Project Sdk="Microsoft.NET.Sdk">

  <!-- ProteinTurnoverArgCollector external-tool arg collector (WinForms library). Multi-target net472;net8.0-windows
       (was classic). Standalone: only framework references. Vestigial System.Deployment dropped;
       any Chinese satellite resx renamed zh-CHS -> zh-Hans to match the branch-wide culture rename. -->
  <PropertyGroup>
    <ProjectGuid>{D1691800-2683-42B8-8C5A-3BEC8FA6DBED}</ProjectGuid>
    <OutputType>Library</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>ProteinTurnoverArgCollector</RootNamespace>
    <AssemblyName>ProteinTurnoverArgCollector</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <!-- Microsoft.VisualBasic.FileIO.TextFieldParser: framework assembly on net472; on net8 it ships
       in the WindowsDesktop shared framework (UseWindowsForms), so no explicit reference needed. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="Microsoft.VisualBasic" />
  </ItemGroup>
</Project>
