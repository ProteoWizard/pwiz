<Project Sdk="Microsoft.NET.Sdk">

  <!-- QuaSAR external-tool arg collector (WinForms library). Multi-target net472;net8.0-windows
       (was classic v4.0 Client). Standalone: only framework references. The vestigial
       System.Deployment reference (no ApplicationDeployment usage) is dropped; the Chinese
       satellite resx is renamed zh-CHS -> zh-Hans to match the branch-wide culture rename. -->
  <PropertyGroup>
    <ProjectGuid>{2E719034-6095-4CA5-A1E1-E1CBE3D74E4A}</ProjectGuid>
    <OutputType>Library</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>QuaSAR</RootNamespace>
    <AssemblyName>QuaSAR</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

</Project>
