<Project Sdk="Microsoft.NET.Sdk">

  <!-- TFExportTool - WinExe (was classic v4.7.2). Multi-target net472;net8.0-windows. The bundled
       CsvHelper.dll is an old net40 build whose API (new CsvConfiguration { CultureInfo = ... })
       predates the modern NuGet's required-ctor API, so reference the same on-disk DLL for BOTH
       TFMs (pure-managed, net8-loadable) rather than a source-breaking upgrade. Vestigial
       System.Deployment dropped; icon.ico embedded as a manifest resource (the SDK doesn't
       auto-embed .ico); Chinese satellite resx renamed zh-CHS -> zh-Hans. -->
  <PropertyGroup>
    <ProjectGuid>{5B8248CA-11AF-4EC1-A89A-B72980EF05B8}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>TFExportTool</RootNamespace>
    <AssemblyName>TFExportTool</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <Reference Include="CsvHelper">
      <HintPath>..\..\CsvHelper.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="icon.ico" />
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
