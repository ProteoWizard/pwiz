<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>SkylineAiConnector</RootNamespace>
    <AssemblyName>SkylineAiConnector</AssemblyName>
    <LangVersion>latest</LangVersion>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ApplicationIcon>SkylineAiConnector.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\SkylineTool\SkylineTool.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <!-- Central Skyline version (YEAR.ORDINAL.BRANCH.DOY), shared with Skyline.csproj,
       so the tool ZIP's info.properties tracks the Skyline version automatically. -->
  <Import Project="..\..\..\..\SkylineVersion.targets" />

  <!-- Build the MCP server before packaging. The server builds with a win-x64
       RuntimeIdentifier and its full output is copied into the tool ZIP's
       mcp-server\ folder by PackageToolZip below, so it stays a separate build
       (restored + built via the SkylineMcp solution) rather than a ProjectReference. -->
  <Target Name="BuildMcpServer" BeforeTargets="PackageToolZip">
    <MSBuild Projects="$(MSBuildProjectDirectory)\..\SkylineMcpServer\SkylineMcpServer.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration)" />
  </Target>

  <!-- Package the Skyline External Tool ZIP after build -->
  <Target Name="PackageToolZip" AfterTargets="Build" DependsOnTargets="ComputeSkylineVersion">
    <PropertyGroup>
      <_ToolZipDir>$(MSBuildProjectDirectory)\bin\$(Configuration)\$(TargetFramework)\SkylineMcp\</_ToolZipDir>
      <_ToolZipPath>$(MSBuildProjectDirectory)\SkylineAiConnector.zip</_ToolZipPath>
      <_ConnectorBinDir>$(MSBuildProjectDirectory)\bin\$(Configuration)\$(TargetFramework)\</_ConnectorBinDir>
      <_McpServerBinDir>$(MSBuildProjectDirectory)\..\SkylineMcpServer\bin\$(Configuration)\net8.0-windows\win-x64\</_McpServerBinDir>
    </PropertyGroup>

    <!-- Clean staging directory -->
    <RemoveDir Directories="$(_ToolZipDir)" />
    <MakeDir Directories="$(_ToolZipDir)" />
    <MakeDir Directories="$(_ToolZipDir)tool-inf\" />
    <MakeDir Directories="$(_ToolZipDir)mcp-server\" />

    <!-- Copy connector output (exe + all dependencies). *.json picks up the net8
         apphost companions (runtimeconfig.json + deps.json) the exe needs to launch. -->
    <ItemGroup>
      <ConnectorFiles Include="$(_ConnectorBinDir)*.exe;$(_ConnectorBinDir)*.dll;$(_ConnectorBinDir)*.config;$(_ConnectorBinDir)*.json" />
    </ItemGroup>
    <Copy SourceFiles="@(ConnectorFiles)" DestinationFolder="$(_ToolZipDir)" />

    <!-- Copy tool-inf (recursive to include docs/ subdirectory) -->
    <ItemGroup>
      <ToolInfFiles Include="$(MSBuildProjectDirectory)\tool-inf\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(ToolInfFiles)" DestinationFolder="$(_ToolZipDir)tool-inf\%(RecursiveDir)" />

    <!-- Stamp the central Skyline version (SkylineVersion.targets) into the staged
         info.properties, replacing the ${version} placeholder. -->
    <Exec Command="powershell -NoProfile -Command &quot;(Get-Content '$(_ToolZipDir)tool-inf\info.properties') -replace '\$\{version\}','$(SkylineNumericVersion)' | Set-Content '$(_ToolZipDir)tool-inf\info.properties'&quot;" />

    <!-- Copy MCP server output -->
    <ItemGroup>
      <McpServerFiles Include="$(_McpServerBinDir)*.exe;$(_McpServerBinDir)*.dll;$(_McpServerBinDir)*.json" />
    </ItemGroup>
    <Copy SourceFiles="@(McpServerFiles)" DestinationFolder="$(_ToolZipDir)mcp-server\" />

    <!-- Create ZIP (delete existing first) -->
    <Delete Files="$(_ToolZipPath)" Condition="Exists('$(_ToolZipPath)')" />
    <!-- ReSharper disable once UnknownTask -->
    <ZipDirectory SourceDirectory="$(_ToolZipDir)" DestinationFile="$(_ToolZipPath)" />

    <Message Importance="high" Text="Tool ZIP created: $(_ToolZipPath)" />
  </Target>

</Project>
