<Project Sdk="Microsoft.NET.Sdk">

  <!-- TestHarness - standalone WinExe test harness for the MSStats arg collectors. Multi-target
       net472;net8.0-windows (was classic v4.7.2). Vestigial System.Deployment + System.Net.Http
       references (unused in source) dropped; Chinese satellite resx renamed zh-CHS -> zh-Hans. -->
  <PropertyGroup>
    <ProjectGuid>{D3574062-97FD-49CE-B89E-E3CA1F0AE44B}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>TestHarness</RootNamespace>
    <AssemblyName>TestHarness</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <ProjectReference Include="..\MSStatGroupComparisonUI\MSStatArgCollectors.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
