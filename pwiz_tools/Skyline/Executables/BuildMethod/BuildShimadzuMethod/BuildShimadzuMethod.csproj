<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildShimadzuMethod - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{EF3B41DF-E823-4CC2-8BFA-26F9A91B059A}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildShimadzuMethod</RootNamespace>
    <AssemblyName>BuildShimadzuMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="MethodConverter"><HintPath>x64\MethodConverter.dll</HintPath></Reference>
    <Reference Include="MethodWriter"><HintPath>x64\MethodWriter.dll</HintPath></Reference>
    <Reference Include="Shimadzu.LabSolutions.IO.IoModule"><HintPath>x64\Shimadzu.LabSolutions.IO.IoModule.dll</HintPath></Reference>
  </ItemGroup>

</Project>
