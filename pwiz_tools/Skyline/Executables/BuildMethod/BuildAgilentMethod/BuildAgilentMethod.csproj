<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildAgilentMethod - Agilent vendor method builder (Exe). FEASIBILITY port to
       net472;net8.0-windows. References the managed MethodCreator.dll for both TFMs. Compile-only. -->
  <PropertyGroup>
    <ProjectGuid>{CE0E2BFB-A9CD-47E5-89C3-D8CDCD62A96D}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildAgilentMethod</RootNamespace>
    <AssemblyName>BuildAgilentMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="MethodCreator"><HintPath>.\MethodCreator.dll</HintPath></Reference>
  </ItemGroup>

</Project>
