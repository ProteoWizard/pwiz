<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildQTRAPMethod - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{93130EBE-6FEF-456C-BCDB-B12E9780C051}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildQTRAPMethod</RootNamespace>
    <AssemblyName>BuildQTRAPMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <!-- Embedded MSTest-v1 (Microsoft.VisualStudio.QualityTools.UnitTestFramework) unit tests are
       excluded: that framework has no net8 build, and the builder EXE is the deliverable. -->
  <ItemGroup>
    <Compile Remove="Test\**" />
  </ItemGroup>

  <!-- Properties/Settings.Designer.cs uses System.Configuration.ApplicationSettingsBase, which is a
       NuGet package on net8 (framework assembly on net472). -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Interop.AcqMethodDir"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.AcqMethodDir.dll</HintPath></Reference>
    <Reference Include="Interop.AcqMethodSvr"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.AcqMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.Analyst"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.Analyst.dll</HintPath></Reference>
    <Reference Include="Interop.AnalystService"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.AnalystService.dll</HintPath></Reference>
    <Reference Include="Interop.MSMethodSvr"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.MSMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.ParameterSvr"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.ParameterSvr.dll</HintPath></Reference>
    <Reference Include="Interop.QueueDispatcher"><HintPath>..\..\..\Method\AbSciex\TQ\Interop.QueueDispatcher.dll</HintPath></Reference>
    <Reference Include="ROTMANLib"><HintPath>..\..\..\Method\AbSciex\TQ\ROTMANLib.dll</HintPath></Reference>
    <Reference Include="StdType"><HintPath>..\..\..\Method\AbSciex\TQ\StdType.dll</HintPath></Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BuildAnalystMethod\BuildAnalystMethod.csproj" />
  </ItemGroup>

</Project>
