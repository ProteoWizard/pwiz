<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildAnalystFullScanMethod - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{45E88416-AC6C-4572-BBA3-1B9B78323F01}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildAnalystFullScanMethod</RootNamespace>
    <AssemblyName>BuildAnalystFullScanMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <!-- Embedded MSTest-v1 (Microsoft.VisualStudio.QualityTools.UnitTestFramework) unit tests are
       excluded: that framework has no net8 build, and the builder EXE is the deliverable. -->
  <ItemGroup>
    <Compile Remove="Test\**" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Interop.AcqMethodSvr"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.AcqMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.Analyst"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.Analyst.dll</HintPath></Reference>
    <Reference Include="Interop.DDEMethodSvr"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.DDEMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.IDAMethodSvr"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.IDAMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.MSMethodSvr"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.MSMethodSvr.dll</HintPath></Reference>
    <Reference Include="Interop.ParameterSvr"><HintPath>..\..\..\Method\AbSciex\TOF\Interop.ParameterSvr.dll</HintPath></Reference>
    <Reference Include="StdType"><HintPath>..\..\..\Method\AbSciex\TOF\StdType.dll</HintPath></Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BuildAnalystMethod\BuildAnalystMethod.csproj" />
  </ItemGroup>

</Project>
