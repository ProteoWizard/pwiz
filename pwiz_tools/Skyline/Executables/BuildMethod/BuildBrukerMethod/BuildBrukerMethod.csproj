<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildBrukerMethod - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{5BF90ED0-C202-4BEE-B028-FCED3AC19A65}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildBrukerMethod</RootNamespace>
    <AssemblyName>BuildBrukerMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="BDal.Submethod.Wrapper"><HintPath>..\..\..\Method\Bruker\BDal.Submethod.Wrapper.dll</HintPath></Reference>
    <Reference Include="BdalRetentionTimeMassList"><HintPath>..\..\..\Method\Bruker\BdalRetentionTimeMassList.dll</HintPath></Reference>
  </ItemGroup>

</Project>
