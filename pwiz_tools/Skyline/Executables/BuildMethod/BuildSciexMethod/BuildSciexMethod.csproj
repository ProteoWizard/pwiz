<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildSciexMethod - Sciex vendor method builder (Exe). FEASIBILITY port to net472;net8.0-windows.
       Uses the modern SCIEX.Apis.Control.v1 SDK (same family as SCIEX.Apis.Data.v1, which already runs
       on net8) + Microsoft.IO.RecyclableMemoryStream, referenced as on-disk DLLs for both TFMs. This
       proves COMPILE feasibility only; runtime needs the installed Sciex control software. -->
  <PropertyGroup>
    <ProjectGuid>{F29A4961-5437-40B8-A38E-FFB4584BC409}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildSciexMethod</RootNamespace>
    <AssemblyName>BuildSciexMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Microsoft.IO.RecyclableMemoryStream"><HintPath>.\Microsoft.IO.RecyclableMemoryStream.dll</HintPath></Reference>
    <Reference Include="SCIEX.Apis.Control.v1"><HintPath>.\SCIEX.Apis.Control.v1.dll</HintPath></Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.Net.Http" />
  </ItemGroup>

</Project>
