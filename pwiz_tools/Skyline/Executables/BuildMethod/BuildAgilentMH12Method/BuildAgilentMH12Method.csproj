<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildAgilentMH12Method - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{0A0180A8-6BCB-41B7-8636-D034B1E629BC}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <!-- net48 (not net472): the Agilent MH12 driver DLLs (Agilent.MSDrivers.LCQuadrupole.*) target
         .NET Framework 4.8, which 4.7.2 cannot reference. 4.8 is an in-place update to 4.7.2. -->
    <TargetFrameworks>net48;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildAgilentMH12Method</RootNamespace>
    <AssemblyName>BuildAgilentMH12Method</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <ItemGroup>
