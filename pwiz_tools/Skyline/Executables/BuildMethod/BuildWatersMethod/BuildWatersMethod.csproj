<Project Sdk="Microsoft.NET.Sdk">

  <!-- BuildWatersMethod - vendor method builder. Ported to multi-target net472;net8.0-windows so it still
       builds/runs on future Windows without .NET Framework 4.7.2. Vendor DLLs are managed and
       referenced for both TFMs; framework + vestigial (UnitTestFramework/Deployment/Net.Http)
       references dropped. Compile-verified; net8 vendor-software runtime is untested. -->
  <PropertyGroup>
    <ProjectGuid>{7C54166D-0A4E-4987-9132-193E1EBF7AAE}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>BuildWatersMethod</RootNamespace>
    <AssemblyName>BuildWatersMethod</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277;MSB3270</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="VerifyESkylineLibrary"><HintPath>..\..\..\Method\Waters\VerifyESkylineLibrary.dll</HintPath></Reference>
  </ItemGroup>

</Project>
