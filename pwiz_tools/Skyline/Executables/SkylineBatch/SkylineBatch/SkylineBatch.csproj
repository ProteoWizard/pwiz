<Project Sdk="Microsoft.NET.Sdk">

  <!-- SkylineBatch - WinForms app for running Skyline command batches. Multi-target
       net472;net8.0-windows (classic v4.7.2). net472 keeps the exact on-disk HintPath DLLs +
       the ClickOnce (System.Deployment) / System.Web assemblies it always used; net8 pulls the
       managed equivalents from NuGet, and the ClickOnce auto-update path is #if NET472-guarded
       (Program.cs - net8 is never network-deployed). Vestigial System.Configuration.Install
       reference dropped. -->
  <PropertyGroup>
    <ProjectGuid>{7AB2D7AD-6760-450E-BCCD-B08502307B99}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>SkylineBatch</RootNamespace>
    <AssemblyName>SkylineBatch</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ApplicationIcon>SkylineBatch.ico</ApplicationIcon>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1605;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <ProjectReference Include="..\..\..\..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\..\..\..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\..\SharedBatch\SharedBatch\SharedBatch.csproj" />
  </ItemGroup>

  <!-- Skyline's command-arg usage strings (pwiz.Skyline.CommandArgUsage), linked from the main
       Skyline project so RefineInputLocalization can localize refine-setting help without
       referencing all of Skyline. Localized resx are inferred as ja / zh-Hans satellites. The
       classic project still referenced the pre-rename CommandArgUsage.zh-CHS.resx (now zh-Hans). -->
  <ItemGroup>
    <Compile Include="..\..\..\CommandArgUsage.Designer.cs">
      <Link>CommandArgUsage.Designer.cs</Link>
      <DependentUpon>CommandArgUsage.resx</DependentUpon>
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
    </Compile>
    <EmbeddedResource Include="..\..\..\CommandArgUsage.resx">
      <Link>CommandArgUsage.resx</Link>
      <LogicalName>pwiz.Skyline.CommandArgUsage.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\..\CommandArgUsage.ja.resx">
      <Link>CommandArgUsage.ja.resx</Link>
      <LogicalName>pwiz.Skyline.CommandArgUsage.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\..\..\CommandArgUsage.zh-Hans.resx">
      <Link>CommandArgUsage.zh-Hans.resx</Link>
      <LogicalName>pwiz.Skyline.CommandArgUsage.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- net8: managed NuGet equivalents of the legacy on-disk DLLs + the settings config provider -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="FluentFTP" Version="33.1.6" />
    <PackageReference Include="DotNetZip" Version="1.16.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

  <!-- net472: the exact on-disk DLLs + the ClickOnce / System.Web assemblies the net8 path drops -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="FluentFTP"><HintPath>..\..\..\..\Shared\Lib\FluentFTP.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\..\..\..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="Newtonsoft.Json"><HintPath>..\..\..\..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="System.Collections.Immutable"><HintPath>..\..\..\..\Shared\Lib\System.Collections.Immutable.dll</HintPath></Reference>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Configuration" />
    <Reference Include="System.Deployment" />
    <Reference Include="System.Management" />
    <Reference Include="System.Security" />
    <Reference Include="System.Web" />
  </ItemGroup>

  <!-- Config-file icon loaded at runtime via BaseDirectory; the app icon is embedded via ApplicationIcon -->
  <ItemGroup>
    <Content Include="SkylineBatch_configs.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Bundled SkylineRunner shims + LaunchBatch launcher. Copied when the pre-built binaries are
       present (the net472 build produces them); the net8 build gets them if present, otherwise
       skips - net8-native bundling of the ported SkylineDailyRunner/LaunchBatch is a follow-on. -->
  <ItemGroup>
    <Content Include="..\..\SkylineRunner\Binaries\SkylineDailyRunner.exe" Condition="Exists('..\..\SkylineRunner\Binaries\SkylineDailyRunner.exe')">
      <Link>SkylineDailyRunner.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\SkylineRunner\Binaries\SkylineRunner.exe" Condition="Exists('..\..\SkylineRunner\Binaries\SkylineRunner.exe')">
      <Link>SkylineRunner.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\SharedBatch\LaunchBatch\obj\$(Configuration)\LaunchBatch.exe" Condition="Exists('..\..\SharedBatch\LaunchBatch\obj\$(Configuration)\LaunchBatch.exe')">
      <Link>LaunchBatch.exe</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
