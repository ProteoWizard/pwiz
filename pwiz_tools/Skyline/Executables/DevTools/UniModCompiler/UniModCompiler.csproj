<Project Sdk="Microsoft.NET.Sdk">

  <!-- UniModCompiler - dev tool that generates UniModData.cs from unimod.xml. Multi-target
       net472;net8.0-windows (the net8 target tracks its CommonUtil project reference, which is
       net8.0-windows). UniModTemplate.cs is a code-gen TEMPLATE embedded as a resource, not a
       compiled source file; the InputFiles data are carried as Content. -->
  <PropertyGroup>
    <ProjectGuid>{B507CA19-F083-4C0D-B321-49F6E6F6D004}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>UniModCompiler</RootNamespace>
    <AssemblyName>UniModCompiler</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Shared\CommonUtil\CommonUtil.csproj" />
  </ItemGroup>

  <!-- UniModTemplate.cs is an embedded code-generation template, not compiled. -->
  <ItemGroup>
    <Compile Remove="UniModTemplate.cs" />
    <EmbeddedResource Include="UniModTemplate.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="InputFiles\get_params.pl.txt" />
    <Content Include="InputFiles\ProteinPilot.DataDictionary.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="InputFiles\unimod.xml" />
  </ItemGroup>

</Project>
