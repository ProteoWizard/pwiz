<Project Sdk="Microsoft.NET.Sdk">

  <!-- OpenSwathConvert - dev/build console utility. Multi-target net472;net8.0 (was classic). Pure console
       (no WinForms/Drawing), so the net8 target is plain net8.0. Only framework references. -->
  <PropertyGroup>
    <ProjectGuid>{E84BAF88-C169-416D-AF6B-F2A1745E4085}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>OpenSwathConvert</RootNamespace>
    <AssemblyName>OpenSwathConvert</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

</Project>
