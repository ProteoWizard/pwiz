<Project Sdk="Microsoft.NET.Sdk">

  <!-- AssortResources - dev tool that splits/reorganizes .resx resources (was classic v4.7.2).
       Multi-target net472;net8.0-windows. Uses System.Resources.ResX* types (which live in
       System.Windows.Forms on net8) via UseWindowsForms. CommandLine: the bundled net461
       CommandLineParser is referenced for both TFMs (net8-loadable; its old API predates the
       modern NuGet). Vestigial System.Net.Http reference dropped. BlankResourcesFile.txt is an
       embedded template. -->
  <PropertyGroup>
    <ProjectGuid>{9E3C78C2-A749-4E6F-809C-ECA0D16CFFD0}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>AssortResources</RootNamespace>
    <AssemblyName>AssortResources</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);NU1701;MSB3277</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="CommandLine">
      <HintPath>lib\CommandLine.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- System.Resources.Tools.StronglyTypedResourceBuilder lives in System.Design.dll on net472;
       on net8 it resolves through the WindowsDesktop reference set (UseWindowsForms). -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Design" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="BlankResourcesFile.txt" />
  </ItemGroup>

</Project>
