<Project Sdk="Microsoft.NET.Sdk">

  <!-- Skyline - the main desktop app. Multi-target net472 + net8.0-windows.
       net472: legacy build, Skyline-daily.exe parity with today.
       net8.0-windows: net8 port, data layer through pwiz-sharp via the
       converted ProteowizardWrapper chokepoint.
       Original csproj was 7,526 lines of enumerated Compile/None/Reference entries;
       the SDK globs everything by default and pairs designer Form/.Designer.cs
       automatically. Where the legacy listed extra metadata (SubType, DependentUpon)
       the SDK rules recover the same association from filenames. -->
  <PropertyGroup>
    <ProjectGuid>{DDA2EA4C-B632-4FDF-94BA-F71E4C152056}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.Skyline</RootNamespace>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Skyline.ico</ApplicationIcon>
    <Company>University of Washington</Company>
    <Product>Skyline</Product>
    <AssemblyTitle>Skyline</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2026</Copyright>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Explicit off to avoid intermittent "Duplicate TargetFrameworkAttribute"
         errors during Test.csproj-driven incremental builds. Skyline has its
         own AssemblyInfo via PreBuildEvents / GenerateAssemblyInfo=false; the
         SDK's auto-gen AssemblyAttributes.cs was intermittently getting
         compiled twice into Skyline.dll. -->
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <!-- See CommonUtil + Common csproj - old transitive deps trigger NU1605
         downgrades that net8's runtime supersedes safely. -->
    <NoWarn>$(NoWarn);NU1605;NU1701;NU1903;SYSLIB0011</NoWarn>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Skyline ships as Skyline-daily.exe in the daily channel; honor the env
         override the build batch uses (PreBuildEvents.bat). -->
    <MSBuildAssemblyName Condition="'$(MSBuildAssemblyName)' == ''">Skyline-daily</MSBuildAssemblyName>
    <AssemblyName>$(MSBuildAssemblyName)</AssemblyName>
    <StartupObject>pwiz.Skyline.Program</StartupObject>
  </PropertyGroup>

  <!-- The Skyline tree has lots of sibling-project sources under Executables/,
       CommonTest/, BullseyeSharp/, Documentation/, etc. - these have their
       own csprojs. Stop the SDK from globbing them into this build. -->
  <ItemGroup>
    <Compile Remove="Executables\**" />
    <Compile Remove="CommonTest\**" />
    <Compile Remove="BullseyeSharp\**" />
    <Compile Remove="Documentation\**" />
    <Compile Remove="Test*\**" />
    <Compile Remove="SkylineTester*\**" />
    <Compile Remove="SkylineNightly\**" />
    <Compile Remove="SkylineNightlyShim\**" />
    <Compile Remove="SkylinePeptideColorGenerator\**" />
    <Compile Remove="MProphetFormulaGenerator\**" />
    <Compile Remove="DocumentationViewer\**" />
    <Compile Remove="HelpGenerator\**" />
    <!-- SkylineCmd is a separate exe project (SkylineCmd.csproj). Its Program.cs uses
         SkylineCmdResources whose .resources are only embedded in SkylineCmd.exe, so
         globbing its sources into Skyline.dll makes LocalizedResourcesTest fail when
         it tries to resolve pwiz.SkylineCmd.SkylineCmdResources.resources from
         Skyline-daily.dll. Legacy csproj didn't include SkylineCmd\ either. -->
    <Compile Remove="SkylineCmd\**" />
    <!-- SkylineTool is its own assembly (SkylineTool.dll), referenced below. Don't glob its
         sources into Skyline-daily.dll: that duplicates the SkylineToolClient types in two
         assemblies and any project referencing both (e.g. TestFunctional) hits CS0433. The
         legacy csproj referenced the project, not its sources. -->
    <Compile Remove="SkylineTool\**" />
    <EmbeddedResource Remove="SkylineTool\**" />
    <None Remove="SkylineTool\**" />
    <EmbeddedResource Remove="SkylineCmd\**" />
    <None Remove="SkylineCmd\**" />
    <EmbeddedResource Remove="Executables\**" />
    <EmbeddedResource Remove="CommonTest\**" />
    <EmbeddedResource Remove="BullseyeSharp\**" />
    <EmbeddedResource Remove="Documentation\**" />
    <EmbeddedResource Remove="Test*\**" />
    <EmbeddedResource Remove="SkylineTester*\**" />
    <None Remove="Executables\**" />
    <None Remove="CommonTest\**" />
    <None Remove="BullseyeSharp\**" />
    <None Remove="Documentation\**" />
    <None Remove="Test*\**" />
    <None Remove="SkylineTester*\**" />
    <!-- ProtocolBuffers/tmp is intermediate protoc output - the real generated
         code lives in GeneratedCode/. Including both gives duplicate types. -->
    <Compile Remove="ProtocolBuffers\tmp\**" />
    <!-- GeneratedCode/*.cs is protoc output (git-ignored) that may not exist at
         evaluation time on a clean checkout, so keep it out of the default glob;
         the GenerateProtobufCode target below regenerates it and injects it into
         @(Compile) so the build is correct even on a fresh agent. -->
    <Compile Remove="ProtocolBuffers\GeneratedCode\**" />
  </ItemGroup>

  <!-- Protobuf/gRPC code generation. The C# under ProtocolBuffers/GeneratedCode/
       is produced from the .proto sources by ProtocolBuffers/generatecode.bat
       (protoc + grpc_csharp_plugin, both committed) and is git-ignored, so a
       clean CI checkout has none - the legacy MSVC/Jam build ran protoc as a
       pre-build step; the net8 SDK build must too. Runs every build but the bat
       only rewrites GeneratedCode files whose content changed (fc.exe diff), so
       it does not churn incremental rebuilds. Compile items are injected here
       rather than via the default glob because the files may not exist when the
       project is evaluated. -->
  <Target Name="GenerateProtobufCode" BeforeTargets="CoreCompile">
    <Exec Command="&quot;$(ProjectDir)ProtocolBuffers\generatecode.bat&quot;" WorkingDirectory="$(ProjectDir)ProtocolBuffers" />
    <ItemGroup>
      <Compile Include="ProtocolBuffers\GeneratedCode\*.cs" />
    </ItemGroup>
  </Target>

  <!-- net8 cuts: remaining features that still can't compile on net8.
       Original scope (Koina/Grpc, MSAmanda, DiaUmpire, Bruker PRM scheduling,
       Unifi/WatersConnect/Ardia remote, IdentityModel) has been restored - see
       commit history for each. What's left: three UI/graph tie-ins that still
       depend on cut infrastructure. Tracked separately for follow-up. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">

    <!-- Controls/Graphs/ReplicateValue.cs is a stale duplicate of
         Model/Results/ReplicateValue.cs (Move ReplicateValue into Model/Results,
         see commit 85cd59f001). Kept excluded on net8 to remove the CS0104
         ambiguity that net472 silently ignored. Unrelated to feature cuts. -->
    <Compile Remove="Controls\Graphs\ReplicateValue.cs" />
  </ItemGroup>

  <!-- NHibernate mapping XMLs. Six Skyline models use NHibernate for
       persistence (BlibData spec libs, ChromLib chromatogram libs, IonMobility
       libraries, Irt tables, Midas libs, Optimization libraries). Each has a
       DataModel-adjacent mapping.xml that must be embedded, not deployed -
       SessionFactoryFactory loads via assembly.GetManifestResourceStream.
       SDK default globs don't include .xml as EmbeddedResource. -->
  <ItemGroup>
    <EmbeddedResource Include="Model\IonMobility\mapping.xml" />
    <EmbeddedResource Include="Model\Irt\mapping.xml" />
    <EmbeddedResource Include="Model\Lib\BlibData\mapping.xml" />
    <EmbeddedResource Include="Model\Lib\BlibData\mapping_redundant.xml" />
    <EmbeddedResource Include="Model\Lib\ChromLib\Data\mapping.xml" />
    <EmbeddedResource Include="Model\Lib\Midas\mapping.xml" />
    <EmbeddedResource Include="Model\Optimization\mapping.xml" />
  </ItemGroup>

  <!-- KoinaConfig.xml holds the Koina server config. The real (secret) file is dropped in for
       official builds and is gitignored; the legacy Jamfile did
       `make KoinaConfig.xml : KoinaConfig_development.xml : @common.copy`, i.e. defaulted to the
       checked-in development config. Embed that development file directly under the resource name
       KoinaConfig.GetKoinaConfig() looks up (assembly.GetManifestResourceStream(typeof(KoinaConfig),
       "KoinaConfig.xml")). Static so it works on a clean checkout with no generated file. -->
  <ItemGroup>
    <EmbeddedResource Include="Model\Koina\Config\KoinaConfig_development.xml">
      <LogicalName>pwiz.Skyline.Model.Koina.Config.KoinaConfig.xml</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- iRT standard documents (Biognosys, Pierce, CiRT, etc.) loaded via
       IrtStandard.GetReader -> assembly.GetManifestResourceStream. Like the
       mapping.xml files above, the SDK default globs don't embed .sky files. -->
  <ItemGroup>
    <EmbeddedResource Include="Model\Irt\StandardsDocuments\*.sky" />
  </ItemGroup>

  <!-- NVIDIA install/uninstall .bat templates loaded via
       GetManifestResourceStream(typeof(PythonInstaller), "...-bat.txt").
       SDK default globs don't embed .txt. -->
  <ItemGroup>
    <EmbeddedResource Include="Model\Tools\InstallNvidiaLibraries-bat.txt" />
    <EmbeddedResource Include="Model\Tools\UninstallNvidiaLibraries-bat.txt" />
  </ItemGroup>

  <!-- log4net runtime config - [DeploymentItem("SkylineLog4Net.config")] in
       AbstractUnitTest.cs assumes this file lands next to the assembly. Legacy
       csproj emitted it via a None entry with CopyToOutputDirectory. SDK glob
       treats .config specially (it's excluded from default None globs) so
       list it explicitly. -->
  <!-- Method/ contains vendor method-builder executables (BuildShimadzuMethod.exe,
       BuildSciexMethod.exe, BuildAnalystMethod.dll, etc.) that Skyline runs at test
       time to export methods. They must be copied to the assembly's bin dir so
       Skyline's ProcessRunner can find them. SDK's None glob doesn't include
       non-code files; enumerate the Method tree explicitly. -->
  <ItemGroup>
    <None Include="Method\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Method\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
  </ItemGroup>

  <ItemGroup>
    <None Include="SkylineLog4Net.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2592.51" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared dep tree - all multi-targeted in the same session as this csproj.
         Each follows the same net472/net8.0-windows split internally. -->
    <ProjectReference Include="..\Shared\BiblioSpec\BiblioSpec.csproj" />
    <ProjectReference Include="..\Shared\CommonFileDialogs\CommonFileDialogs.csproj" />
    <ProjectReference Include="..\Shared\CommonMsData\CommonMsData.csproj" />
    <ProjectReference Include="..\Shared\Common\Common.csproj" />
    <ProjectReference Include="..\Shared\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\Shared\MSGraph\MSGraph.csproj" />
    <ProjectReference Include="..\Shared\PortableUtil\PortableUtil.csproj" />
    <ProjectReference Include="..\Shared\PanoramaClient\PanoramaClient.csproj" />
    <ProjectReference Include="..\Shared\ProteomeDb\ProteomeDb.csproj" />
    <ProjectReference Include="..\Shared\ProteowizardWrapper\ProteowizardWrapper.csproj" />
    <ProjectReference Include="..\Shared\zedgraph\ZedGraph.csproj" />
    <ProjectReference Include="SkylineTool\SkylineTool.csproj" />

    <!-- BiblioSpec CLI tools (BlibBuild, BlibFilter). Skyline shells out to these via
         ProcessStartInfo expecting them to sit next to Skyline in the bin dir. Reference
         the projects so they build first; the Content include below deploys their outputs. -->
    <ProjectReference Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\BlibBuild.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
    <ProjectReference Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibFilter\BlibFilter.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
  </ItemGroup>

  <!-- Copy BlibBuild.exe / BlibFilter.exe + their runtime deps (unimod.xml etc.) to
       Skyline's bin dir AND to any project that references Skyline via ProjectReference
       (test assemblies). Content items propagate through ProjectReference by default. -->
  <ItemGroup>
    <Content Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0\**\*"
             Condition="Exists('..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <Visible>false</Visible>
    </Content>
    <Content Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibFilter\bin\$(Configuration)\net8.0\**\*"
             Condition="Exists('..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibFilter\bin\$(Configuration)\net8.0')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- BlibBuild reads Mascot .dat results through the native MascotShim.dll wrapper and its
       msparser.dll dependency, emitted under BlibBuild's runtimes\win-x64\native\. The wildcard
       Content above does not deploy files whose Link lands under runtimes\...\ into consuming bins
       (they collide with RID-specific native-asset handling), so the mascot reader was missing at
       run time. Deploy the mascot natives flat next to BlibBuild.exe - as legacy Skyline shipped
       msparser.dll - so DllImport("MascotShim") and its msparser dependency resolve from the
       executable's own directory. -->
  <ItemGroup Condition="Exists('..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0\runtimes\win-x64\native')">
    <Content Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0\runtimes\win-x64\native\MascotShim.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>MascotShim.dll</Link>
      <Visible>false</Visible>
    </Content>
    <Content Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0\runtimes\win-x64\native\msparser.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>msparser.dll</Link>
      <Visible>false</Visible>
    </Content>
    <Content Include="..\..\pwiz-sharp\Tools\BiblioSpec\src\BlibBuild\bin\$(Configuration)\net8.0\runtimes\win-x64\native\msparser-config\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>msparser-config\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- msconvert (managed pwiz-sharp port). Skyline shells out to msconvert for DIA-Umpire and
       EncyclopeDIA demultiplexing conversions, expecting msconvert.exe next to Skyline in the bin
       dir (resolved via PathEx.ResolveBundledExe). Reference the project so it builds first; the
       Content include below deploys its output. net8-only: the net472 build gets the native
       msconvert from the Jam toolchain. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <ProjectReference Include="..\..\pwiz-sharp\Tools\Commandline\MsConvert\src\MsConvert.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' And Exists('..\..\pwiz-sharp\Tools\Commandline\MsConvert\src\bin\$(Configuration)\net8.0')">
    <Content Include="..\..\pwiz-sharp\Tools\Commandline\MsConvert\src\bin\$(Configuration)\net8.0\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- BullseyeSharp (managed pwiz-sharp port; its AssemblyName is "bullseye-sharp", so it emits
       bullseye-sharp.exe). Skyline's Hardklor feature-detection pipeline shells out to it to match
       MS1 features against MS2 scans, expecting bullseye-sharp.exe next to Skyline in the bin dir
       (resolved via PathEx.ResolveBundledExe). Reference the project so it builds first; the Content
       include below deploys its output. net8-only: the net472 build gets the legacy BullseyeSharp.exe
       from pwiz_tools\Skyline\BullseyeSharp\BullseyeSharp.csproj via the Jam toolchain. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <ProjectReference Include="..\..\pwiz-sharp\Tools\BullseyeSharp\src\BullseyeSharp.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' And Exists('..\..\pwiz-sharp\Tools\BullseyeSharp\src\bin\$(Configuration)\net8.0')">
    <Content Include="..\..\pwiz-sharp\Tools\BullseyeSharp\src\bin\$(Configuration)\net8.0\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- Hardklor (native x64 C++ feature-detection tool). Skyline's Hardklor/Bullseye pipeline
       shells out to Hardklor.exe next to Skyline in the bin dir (resolved via
       PathEx.ResolveBundledExe). Unlike the managed tools above, Hardklor is C++ and cannot be
       built by `dotnet build`, so it is produced by a separate VS MSBuild step that builds
       Executables\Hardklor\Hardklor.vcxproj before this project (see pwiz_tools\Skyline\build.bat).
       This Content include deploys the pre-built exe when present. net8-only: the net472 build
       gets Hardklor.exe from the Jam toolchain. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' And Exists('Executables\Hardklor\bin\x64\$(Configuration)\Hardklor.exe')">
    <Content Include="Executables\Hardklor\bin\x64\$(Configuration)\Hardklor.exe">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Hardklor.exe</Link>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <!-- SkylineCmd.exe launcher - command-line tests (e.g. CmdLineAssociateProteinsTest)
       shell out to it expecting it next to Skyline in the bin dir. Reference it so it
       builds first. net8-only: the net472 build gets SkylineCmd from the Jam toolchain. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <ProjectReference Include="SkylineCmd\SkylineCmd.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false" />
  </ItemGroup>
  <!-- SkylineCmd is built inline via the ProjectReference above, so its bin does NOT exist
       when this project's items are first evaluated - a static Content glob captures nothing
       on a clean build, and target-added Content doesn't reliably propagate cross-project.
       Copy its output next to Skyline after Build (bin exists by then). Test projects that run
       SkylineCmd do the same copy into their own output (see Test.csproj). -->
  <Target Name="_DeploySkylineCmd"
          Condition="'$(TargetFramework)' == 'net8.0-windows'"
          AfterTargets="Build">
    <ItemGroup>
      <_SkylineCmdOutput Include="SkylineCmd\bin\$(Configuration)\net8.0-windows\SkylineCmd.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_SkylineCmdOutput)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="'@(_SkylineCmdOutput)' != ''" />
  </Target>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <!-- Legacy bundled DLLs, kept verbatim for net472 build parity. -->
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Web" />
    <Reference Include="System.Security" />
    <Reference Include="System.Deployment" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="Accessibility" />
    <Reference Include="EnvDTE">
      <EmbedInteropTypes>True</EmbedInteropTypes>
    </Reference>
    <Reference Include="Excel.4.5">
      <HintPath>..\Shared\Lib\Excel.4.5.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
    </Reference>
    <Reference Include="Dapper"><HintPath>..\Shared\Lib\Dapper.dll</HintPath></Reference>
    <Reference Include="DigitalRune.Windows.Docking"><HintPath>..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath></Reference>
    <Reference Include="Google.Protobuf"><HintPath>..\Shared\Lib\Google.Protobuf.dll</HintPath></Reference>
    <Reference Include="DotNetZip"><HintPath>..\Shared\Lib\DotNetZip\DotNetZip.dll</HintPath></Reference>
    <Reference Include="Grpc.Core"><HintPath>..\Shared\Lib\Grpc.Core.dll</HintPath></Reference>
    <Reference Include="Grpc.Core.Api"><HintPath>..\Shared\Lib\Grpc.Core.Api.dll</HintPath></Reference>
    <Reference Include="IdentityModel"><HintPath>..\Shared\Lib\IdentityModel.dll</HintPath></Reference>
    <Reference Include="JetBrains.Annotations"><HintPath>..\Shared\Lib\JetBrains.Annotations.dll</HintPath></Reference>
    <Reference Include="Kajabity Tools"><HintPath>..\Shared\Lib\Kajabity Tools.dll</HintPath></Reference>
    <Reference Include="log4net"><HintPath>..\Shared\Lib\log4net.dll</HintPath></Reference>
    <Reference Include="MathNet.Numerics"><HintPath>..\Shared\Lib\MathNet.Numerics.dll</HintPath></Reference>
    <Reference Include="Newtonsoft.Json"><HintPath>..\Shared\Lib\Newtonsoft.Json.dll</HintPath></Reference>
    <Reference Include="ParquetNet"><HintPath>..\Shared\Lib\Parquet\ParquetNet.dll</HintPath></Reference>
    <Reference Include="IronCompress"><HintPath>..\Shared\Lib\Parquet\IronCompress.dll</HintPath></Reference>
    <Reference Include="System.Reflection.Emit.Lightweight"><HintPath>..\Shared\Lib\Parquet\System.Reflection.Emit.Lightweight.dll</HintPath></Reference>
    <Reference Include="Microsoft.IO.RecyclableMemoryStream"><HintPath>..\Shared\Lib\Parquet\Microsoft.IO.RecyclableMemoryStream.dll</HintPath></Reference>
    <Reference Include="Snappier"><HintPath>..\Shared\Lib\Parquet\Snappier.dll</HintPath></Reference>
    <Reference Include="System.Text.Encodings.Web"><HintPath>..\Shared\Lib\Parquet\System.Text.Encodings.Web.dll</HintPath></Reference>
    <Reference Include="System.Text.Json"><HintPath>..\Shared\Lib\Parquet\System.Text.Json.dll</HintPath></Reference>
    <Reference Include="ZstdSharp"><HintPath>..\Shared\Lib\Parquet\ZstdSharp.dll</HintPath></Reference>
    <Reference Include="Microsoft.Diagnostics.Runtime"><HintPath>..\Shared\Lib\Microsoft.Diagnostics.Runtime.dll</HintPath></Reference>
    <Reference Include="Iesi.Collections"><HintPath>..\Shared\Lib\NHibernate\Iesi.Collections.dll</HintPath></Reference>
    <Reference Include="NHibernate"><HintPath>..\Shared\Lib\NHibernate\NHibernate.dll</HintPath></Reference>
    <Reference Include="Sprache"><HintPath>..\Shared\Lib\Sprache.dll</HintPath></Reference>
    <Reference Include="System.Data.SQLite">
      <HintPath>..\..\libraries\SQLite\$(PLATFORM)\System.Data.SQLite.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- Net8 NuGet equivalents. Some legacy references have no direct net8
         replacement (DigitalRune.Windows.Docking, FHOOE MSAmanda, Excel interop);
         the source touching those is wrapped in #if NET472 as it surfaces. -->
    <PackageReference Include="Google.Protobuf" Version="3.27.3" />
    <!-- Grpc.Net.Client is the net8 replacement for the legacy Grpc.Core native
         channel. The generated code in ProtocolBuffers/GeneratedCode/ targets
         Grpc.Core.Api types (ClientBase, ChannelBase, CallInvoker, Marshallers)
         which Grpc.Net.Client supplies transitively via Grpc.Core.Api 2.66. -->
    <PackageReference Include="Grpc.Net.Client" Version="2.66.0" />
    <PackageReference Include="DotNetZip" Version="1.16.0" />
    <PackageReference Include="JetBrains.Annotations" Version="2024.3.0" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <PackageReference Include="MathNet.Numerics" Version="4.15.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="NHibernate" Version="5.5.2" />
    <PackageReference Include="Iesi.Collections" Version="4.0.5" />
    <PackageReference Include="Sprache" Version="2.3.1" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <PackageReference Include="Dapper" Version="2.1.35" />
    <PackageReference Include="Parquet.Net" Version="4.25.0" />
    <PackageReference Include="IdentityModel" Version="7.0.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.0" />
    <PackageReference Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <!-- DigitalRune.Windows.Docking is a legacy WinForms DLL with no NuGet
         equivalent. WinForms-on-net8 compat usually loads it fine - reference
         the same binary the legacy build uses. -->
    <Reference Include="DigitalRune.Windows.Docking">
      <HintPath>..\Shared\Lib\DigitalRune.Windows.Docking.dll</HintPath>
    </Reference>
    <Reference Include="Kajabity Tools">
      <HintPath>..\Shared\Lib\Kajabity Tools.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- Bruker timsTOF PRM scheduler: managed replacement for the legacy C++/CLI
       pwiz.CLI.Bruker.PrmScheduling assembly. P/Invokes prmscheduler.dll shipped
       inside pwiz. Only wired for net8; net472 keeps the old C++/CLI reference. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <ProjectReference Include="..\..\pwiz-sharp\pwiz\src\Vendor\Bruker.PrmScheduling\Bruker.PrmScheduling.csproj" />
  </ItemGroup>

  <!-- Build batch hooks (preserved from legacy) - PreBuildEvents.bat is what
       computes Skyline-daily-vs-Skyline assembly name and writes the
       AssemblyInfo override. -->
  <Target Name="SkylinePreBuild" BeforeTargets="BeforeBuild" Condition="Exists('$(ProjectDir)PreBuildEvents.bat')">
    <Exec Command="&quot;$(ProjectDir)PreBuildEvents.bat&quot;" />
  </Target>

  <!-- Legacy AfterPublish signing step - Skyline.sln drives it only for the
       Release configurations. -->
  <Target Name="AfterPublish" Condition="Exists('$(ProjectDir)SignAfterPublishKey.bat')">
    <Exec Command="SignAfterPublishKey.bat &quot;$(ProjectDir)University of Washington (MacCoss Lab).crt&quot; &quot;$(ProjectDir)bin\$(Platform)\$(ConfigurationName)\app.publish&quot; $(TargetName)" />
  </Target>

  <!-- net472 gets its version from the Jam-generated Properties\AssemblyInfo.cs
       (generate-skyline-AssemblyInfo.cs). A plain `dotnet build` (net8) never runs
       Jam, so with GenerateAssemblyInfo=false the assembly would report 1.0.0.0 and
       Install.MajorVersion/MinorVersion would be wrong. Stamp it here, Jam-free:
       compose Skyline's scheme YEAR.ORDINAL.DOY (DOY accumulates across years like
       Jamfile.jam: (YY - YEAR)*365 + day-of-year of the git commit date) and write
       the AssemblyInformationalVersion attribute (Install reads it, stripping the
       "(developer build)"/"(automated build)" suffix). YEAR/ORDINAL mirror
       SKYLINE_YEAR/SKYLINE_ORDINAL in Jamfile.jam; the git-date pieces come from
       pwiz-sharp\build\PwizVersion.targets. Override with -p:SkylineInformationalVersion=… . -->
  <Import Project="..\..\pwiz-sharp\build\PwizVersion.targets"
          Condition="'$(TargetFramework)' == 'net8.0-windows' and Exists('..\..\pwiz-sharp\build\PwizVersion.targets')" />
  <PropertyGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <SkylineVersionYear>26</SkylineVersionYear>
    <SkylineVersionOrdinal>1</SkylineVersionOrdinal>
    <!-- 0 = release, 1 = daily, 9 = feature-complete daily (mirrors SKYLINE_BRANCH
         in Jamfile.jam). This is the .Build component, which TestDocumentFormatCurrent
         keys off (skips the version/format sync check on feature-complete builds). -->
    <SkylineVersionBranch>1</SkylineVersionBranch>
    <_SkylineBuildKindSuffix Condition="'$(AutomatedBuild)' == 'true'">automated build</_SkylineBuildKindSuffix>
    <_SkylineBuildKindSuffix Condition="'$(AutomatedBuild)' != 'true'">developer build</_SkylineBuildKindSuffix>
  </PropertyGroup>
  <Target Name="StampNet8InformationalVersion"
          Condition="'$(TargetFramework)' == 'net8.0-windows'"
          DependsOnTargets="ComputePwizBuildVersion"
          BeforeTargets="CoreCompile">
    <PropertyGroup>
      <!-- Floor at 0: a commit dated before SkylineVersionYear (e.g. building an older commit
           after the base year was bumped) would otherwise yield a negative, invalid version component. -->
      <_SkylineDoy>$([System.Math]::Max(0, $([MSBuild]::Add($([MSBuild]::Multiply($([MSBuild]::Subtract($(PwizVersionYear2), $(SkylineVersionYear))), 365)), $(PwizVersionDayOfYearRaw)))))</_SkylineDoy>
      <!-- Plain numeric version YEAR.ORDINAL.BRANCH.DOY, e.g. 26.1.1.181 -->
      <SkylineNumericVersion Condition="'$(SkylineNumericVersion)' == ''">$(SkylineVersionYear).$(SkylineVersionOrdinal).$(SkylineVersionBranch).$(_SkylineDoy)</SkylineNumericVersion>
      <SkylineInformationalVersion Condition="'$(SkylineInformationalVersion)' == ''">$(SkylineNumericVersion)-$(PwizVersionGitHash) ($(_SkylineBuildKindSuffix))</SkylineInformationalVersion>
    </PropertyGroup>
    <ItemGroup>
      <AssemblyAttribute Include="System.Reflection.AssemblyVersionAttribute">
        <_Parameter1>$(SkylineNumericVersion)</_Parameter1>
      </AssemblyAttribute>
      <AssemblyAttribute Include="System.Reflection.AssemblyFileVersionAttribute">
        <_Parameter1>$(SkylineNumericVersion)</_Parameter1>
      </AssemblyAttribute>
      <AssemblyAttribute Include="System.Reflection.AssemblyInformationalVersionAttribute">
        <_Parameter1>$(SkylineInformationalVersion)</_Parameter1>
      </AssemblyAttribute>
    </ItemGroup>
    <WriteCodeFragment AssemblyAttributes="@(AssemblyAttribute)"
                       Language="C#"
                       OutputDirectory="$(IntermediateOutputPath)"
                       OutputFile="Net8Version.g.cs">
      <Output TaskParameter="OutputFile" ItemName="Compile" />
    </WriteCodeFragment>
  </Target>

</Project>
