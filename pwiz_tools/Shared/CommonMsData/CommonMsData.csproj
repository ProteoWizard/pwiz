<Project Sdk="Microsoft.NET.Sdk">

  <!-- CommonMsData — multi-target net472 + net8.0-windows. Pure-managed wrapper
       (no direct pwiz.CLI dependencies); sits on top of ProteowizardWrapper.
       219 Skyline files import this namespace. -->
  <PropertyGroup>
    <ProjectGuid>{86F8E7F5-A3ED-4519-9AD9-BF9ABD6DD69F}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.CommonMsData</RootNamespace>
    <AssemblyName>pwiz.CommonMsData</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Company>University of Washington</Company>
    <Product>CommonMsData</Product>
    <AssemblyTitle>CommonMsData</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2026</Copyright>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\ProteowizardWrapper\ProteowizardWrapper.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Web" />
    <Reference Include="IdentityModel">
      <HintPath>..\Lib\IdentityModel.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>..\Lib\Newtonsoft.Json.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="IdentityModel" Version="7.0.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <!-- WatersConnectAccount.cs uses IHttpClientFactory — Microsoft.Extensions.Http
         on net8 ships it; net472's System.Net.Http handles HTTP itself. -->
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.0" />
  </ItemGroup>

</Project>
