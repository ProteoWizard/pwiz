<Project Sdk="Microsoft.NET.Sdk">

  <!-- CommonUtil — multi-target net472 + net8.0-windows.
       net472: legacy Skyline build path (Skyline.sln) — keeps building exactly as today.
       net8.0-windows: Skyline net8 port path. Same .cs source compiles under both,
       with #if NET472 / NET8_0_OR_GREATER conditional compilation where needed
       (currently just ConcurrencyVisualizer.cs which references a VS-tooling-only
       Microsoft.ConcurrencyVisualizer.Markers DLL not available on net8).
       Pattern mirrors PortableUtil.csproj alongside this one. -->
  <PropertyGroup>
    <ProjectGuid>{13BF2FFB-50A1-4AB1-83A4-5733E36905CE}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.Common</RootNamespace>
    <AssemblyName>pwiz.CommonUtil</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Company>University of Washington</Company>
    <Copyright>Copyright (c) University of Washington 2026</Copyright>
    <!-- Legacy AssemblyInfo.cs under Properties/ owns the version + GUID + title
         attributes; suppress SDK-generated stamps so they don't collide. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- SDK-style csprojs with non-string .resx resources need both a packaged
         System.Resources.Extensions reference AND this flag to serialize them
         on net472. Without these the build hits MSB3822/MSB3823. -->
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
  </PropertyGroup>

  <ItemGroup>
    <!-- Both targets need System.Resources.Extensions for the preserialized-resource
         path (see GenerateResourceUsePreserializedResources above). -->
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- HintPath-loaded legacy DLLs, kept net472-only so the existing build
         path keeps using exactly the binaries it always has. -->
    <!-- net472 BCL assemblies that the SDK doesn't reference by default. -->
    <Reference Include="System.Net.Http" Condition="'$(TargetFramework)' == 'net472'" />
    <Reference Include="System.Web" Condition="'$(TargetFramework)' == 'net472'" />
    <Reference Include="System.Security" Condition="'$(TargetFramework)' == 'net472'" />
    <Reference Include="JetBrains.Annotations" Condition="'$(TargetFramework)' == 'net472'">
      <HintPath>..\Lib\JetBrains.Annotations.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json" Condition="'$(TargetFramework)' == 'net472'">
      <HintPath>..\Lib\Newtonsoft.Json.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Microsoft.ConcurrencyVisualizer.Markers, Version=12.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL"
              Condition="'$(TargetFramework)' == 'net472'">
      <HintPath>..\Lib\Microsoft.ConcurrencyVisualizer.Markers.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- net8 replacements via NuGet. Versions pinned to track the legacy
         bundled DLLs so behavior doesn't drift. -->
    <PackageReference Include="JetBrains.Annotations" Version="2024.3.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <!-- File-list defaults: SDK style picks up every *.cs under the project dir,
       so adding/removing source files doesn't require csproj edits. -->

</Project>
