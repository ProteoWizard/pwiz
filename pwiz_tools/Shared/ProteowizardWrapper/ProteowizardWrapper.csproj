<Project Sdk="Microsoft.NET.Sdk">

  <!-- ProteowizardWrapper — the Phase-2 chokepoint. Multi-target net472 (legacy
       pwiz.CLI bindings) + net8.0-windows (pwiz-sharp managed port).

       Same MsDataFileImpl class name and public surface in both targets. The
       net472 legacy MsDataFileImpl.cs is excluded on net8.0-windows — instead
       we pull the parallel implementation from the
       ../ProteowizardWrapper.PwizSharp/ sandbox directory, which has the same
       public API but uses pwiz-sharp internally. Eventually the sandbox file
       gets merged in-place but for now this lets Skyline link against pwiz-sharp
       on net8 with zero call-site changes. -->
  <PropertyGroup>
    <ProjectGuid>{DACEE7D5-5A6A-4001-9602-FAB1A9A2DE59}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.ProteowizardWrapper</RootNamespace>
    <AssemblyName>ProteowizardWrapper</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Company>University of Washington</Company>
    <Product>ProteowizardWrapper</Product>
    <AssemblyTitle>ProteowizardWrapper</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2026</Copyright>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>None</ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <!-- Legacy pwiz.CLI bindings + vendor SDK assemblies. Same set Skyline.sln
         resolves today. -->
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Web" />
    <Reference Include="System.Security" />
    <Reference Include="MassSpecDataReader">
      <HintPath>..\Lib\MassSpec\MassSpecDataReader.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="SCIEX.Apis.Data.v1">
      <HintPath>..\Lib\SCIEX.Apis.Data.v1.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="ThermoFisher.CommonCore.Data">
      <HintPath>..\Lib\Thermo\ThermoFisher.CommonCore.Data.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="pwiz_data_cli" Condition="'$(PwizCliAssembly)' == ''">
      <HintPath>..\Lib\pwiz_data_cli.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="$(PwizCliAssembly)" Condition="'$(PwizCliAssembly)' != ''">
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- On net8 the data layer comes from pwiz-sharp. No pwiz.CLI, no
         C++/CLI bindings. -->
    <ProjectReference Include="..\..\..\pwiz-sharp\pwiz\src\MsData\MsData.csproj" />
    <ProjectReference Include="..\..\..\pwiz-sharp\pwiz\src\Analysis\Analysis.csproj" />
    <ProjectReference Include="..\..\..\pwiz-sharp\pwiz\src\Common\Common.csproj" />
    <ProjectReference Include="..\..\..\pwiz-sharp\pwiz\src\Util\Util.csproj" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommonUtil\CommonUtil.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- On net8 swap legacy MsDataFileImpl + siblings for the pwiz-sharp-backed
         sandbox implementation (same public surface, different internals). -->
    <Compile Remove="MsDataFileImpl.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" />
    <Compile Remove="MsDataFileInfo.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" />
    <Compile Remove="IterationListenerToMonitor.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" />
    <Compile Remove="DiaUmpire.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" />
    <Compile Include="..\ProteowizardWrapper.PwizSharp\MsDataFileImpl.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" Link="MsDataFileImpl.cs" />
    <Compile Include="..\ProteowizardWrapper.PwizSharp\MsInstrumentConfigInfo.cs" Condition="'$(TargetFramework)' == 'net8.0-windows'" Link="MsInstrumentConfigInfo.cs" />
  </ItemGroup>

</Project>
