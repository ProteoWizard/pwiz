<Project Sdk="Microsoft.NET.Sdk">

  <!-- ProteomeDb — multi-target net472 + net8.0-windows. Depends on Common +
       CommonUtil. NHibernate + SQLite proteome layer. -->
  <PropertyGroup>
    <ProjectGuid>{09FC3CB3-FCCD-4906-A370-160B28725936}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.ProteomeDatabase</RootNamespace>
    <AssemblyName>ProteomeDb</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Company>University of Washington</Company>
    <Product>ProteomeDb</Product>
    <AssemblyTitle>ProteomeDb</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2026</Copyright>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <NoWarn>$(NoWarn);NU1605</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Forms/ contains a dev-only diagnostic UI not part of the legacy build
         (the legacy csproj enumerated 19 files; Forms/ProteomeDbForm.{cs,
         Designer.cs} were never in the list). Exclude to match. -->
    <Compile Remove="Forms\**" />
    <EmbeddedResource Remove="Forms\**" />
    <None Remove="Forms\**" />
    <!-- NHibernate mapping XML. SessionFactoryFactory.ConfigureMappings loads
         DataModel/mapping.xml via assembly.GetManifestResourceStream - the file
         must be embedded, not just deployed. SDK default glob picks up .resx
         but not .xml, so list it explicitly. -->
    <EmbeddedResource Include="DataModel\mapping.xml" />
    <!-- IPI->UniProt map loaded via GetManifestResourceStream in IpiToUniprotMap.cs;
         SDK default globs don't embed .zip. -->
    <EmbeddedResource Include="Fasta\IpiToUniprotMap.zip" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Common\Common.csproj" />
    <ProjectReference Include="..\CommonUtil\CommonUtil.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Web" />
    <Reference Include="Google.Protobuf">
      <HintPath>..\Lib\Google.Protobuf.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Iesi.Collections">
      <HintPath>..\Lib\NHibernate\Iesi.Collections.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="DotNetZip">
      <HintPath>..\Lib\DotNetZip\DotNetZip.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="NHibernate">
      <HintPath>..\Lib\NHibernate\NHibernate.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.118" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Google.Protobuf" Version="3.27.3" />
    <PackageReference Include="NHibernate" Version="5.5.2" />
    <PackageReference Include="Iesi.Collections" Version="4.0.5" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
  </ItemGroup>

</Project>
