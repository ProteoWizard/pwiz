<Project Sdk="Microsoft.NET.Sdk">

  <!-- CommonFileDialogs — multi-target net472 + net8.0-windows. WinForms
       file-picker dialogs, depends on CommonUtil + CommonMsData + ProteowizardWrapper. -->
