    <ProjectGuid>{B8E3F4A1-7C2D-4E5F-9A1B-3C6D8E0F2A4B}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.CommonFileDialogs</RootNamespace>
    <AssemblyName>pwiz.CommonFileDialogs</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Company>University of Washington</Company>
    <Product>CommonFileDialogs</Product>
    <AssemblyTitle>CommonFileDialogs</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2026</Copyright>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\CommonMsData\CommonMsData.csproj" />
    <ProjectReference Include="..\ProteowizardWrapper\ProteowizardWrapper.csproj" />
  </ItemGroup>

</Project>
