<Project Sdk="Microsoft.NET.Sdk">

  <!-- Common — multi-target net472 + net8.0-windows. The biggest mid-tier
       Shared library. Depends on CommonUtil + MSGraph + ZedGraph (all already
       multi-targeted) and a handful of HintPath legacy DLLs that have NuGet
       equivalents on net8. -->
  <PropertyGroup>
    <ProjectGuid>{A5527BE9-4A62-458F-AE47-F0F9204A5CF9}</ProjectGuid>
    <TargetFrameworks>net472;net8.0-windows</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>pwiz.Common</RootNamespace>
    <AssemblyName>pwiz.Common</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <RuntimeIdentifiers>win;win-x64;win-x86</RuntimeIdentifiers>
    <!-- net472 keeps using Properties/AssemblyInfo.cs (legacy parity); net8 lets the
         SDK generate the company/product/title/copyright attributes from project
         metadata. AssemblyInfo.cs gates those lines with #if NET472. -->
    <Company>University of Washington</Company>
    <Product>Common</Product>
    <AssemblyTitle>Common</AssemblyTitle>
    <Copyright>Copyright © University of Washington 2009-2011</Copyright>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <!-- Old NETStandard.Library 1.6 (transitive via NHibernate→Antlr3.Runtime) requests
         old versions of System.* meta-packages that net8 supersedes at runtime; the
         NU1605 "downgrade" is benign here. Suppress only on net8 — net472 doesn't hit
         the issue because it has its own BCL story. -->
    <NoWarn>$(NoWarn);NU1605</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
    <!-- WebView2 was already a PackageReference in the legacy csproj; safe on both targets. -->
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.864.35" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommonUtil\CommonUtil.csproj" />
    <ProjectReference Include="..\MSGraph\MSGraph.csproj" />
    <ProjectReference Include="..\zedgraph\ZedGraph.csproj" />
  </ItemGroup>

  <!-- DocumentationGenerator.GetStyleSheetHtml() loads this stylesheet via
       assembly.GetManifestResourceStream(typeof(DocumentationGenerator), "DocumentationGenerator.css")
       and returns an empty stylesheet if it isn't embedded. SDK default globs don't embed .css. -->
  <ItemGroup>
    <EmbeddedResource Include="DataBinding\Documentation\DocumentationGenerator.css" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
    <!-- Legacy bundled DLLs — kept for the net472 path so behavior matches today. -->
    <Reference Include="Iesi.Collections">
      <HintPath>..\Lib\NHibernate\Iesi.Collections.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="log4net">
      <HintPath>..\Lib\log4net.dll</HintPath>
      <Private>True</Private>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="MathNet.Numerics">
      <HintPath>..\Lib\MathNet.Numerics.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="NHibernate">
      <HintPath>..\Lib\NHibernate\NHibernate.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Sprache">
      <HintPath>..\Lib\Sprache.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <!-- Legacy used a $(PLATFORM)-substituted HintPath; SDK doesn't evaluate
         $(PLATFORM) the same way. Use the NuGet package for both targets;
         the package's bundled native handles the platform routing. -->
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.118" Condition="'$(TargetFramework)' == 'net472'" />
    <Reference Include="System.Web" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <!-- net8 replacements. NHibernate 5.5+ supports net6+. log4net 2.x is net6+
         compatible. MathNet, Sprache, System.Data.SQLite.Core all multi-target
         to net6+. -->
    <!-- NHibernate 5.5's transitive Antlr3.Runtime 3.5.1 pulls in NETStandard.Library 1.6
         which forces NU1605 package downgrades on net8. Use the modern 5.5.x line that
         drops the Antlr3.Runtime dep, OR upgrade Antlr to a net-compatible version. -->
    <PackageReference Include="NHibernate" Version="5.5.2" />
    <PackageReference Include="Iesi.Collections" Version="4.0.5" />
    <PackageReference Include="log4net" Version="2.0.17" />
    <!-- MathNet 5.0 removed Control.LinearAlgebraProvider and the internal
         Resources class. 4.15.x preserves the legacy API surface Skyline uses
         while still targeting net6+. -->
    <PackageReference Include="MathNet.Numerics" Version="4.15.0" />
    <PackageReference Include="Sprache" Version="2.3.1" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
  </ItemGroup>

</Project>
