<?xml version="1.0" encoding="utf-8"?>
<!-- net472 server GC (ignored on net8; see Directory.Build.props for the
     equivalent runtimeconfig.json settings used by net8). NuGet binding
     redirects are auto-generated at build time; no manual entries needed. -->
<configuration>
  <runtime>
    <gcServer enabled="true"/>
    <gcConcurrent enabled="true"/>
  </runtime>
</configuration>
